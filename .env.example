# Copy this file to ".env.local" in the repo root and fill real keys.
# Keep secrets server-side only. Do not prefix with VITE_.

# CopilotKit runtime provider: "openrouter" (recommended) or "anthropic"
COPILOTKIT_PROVIDER=openrouter

# OpenRouter setup
OPENROUTER_API_KEY=sk-or-your-key
# Use an OpenAI-compatible model on OpenRouter for best CopilotKit tool-call stability.
COPILOTKIT_OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=gallery-poc

# Optional: direct Anthropic fallback
# ANTHROPIC_API_KEY=sk-ant-your-key
# COPILOTKIT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Web search providers (configure at least one)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Route providers (configure at least one for distance/duration metadata)
# GOOGLE_MAPS_API_KEY is preferred (Google Routes API v2).
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# Asset/media providers (configure any you plan to use)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
GIPHY_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=
# Optional Pinterest API (official). Without this, pinterest uses web reference discovery fallback.
PINTEREST_ACCESS_TOKEN=
PINTEREST_COUNTRY_CODE=US
PINTEREST_LOCALE=en-US
PINTEREST_ENABLE_PARTNER_SEARCH=true

# Optional live/embed providers already supported by canvas
# Snapshot template placeholders: {url} {urlEncoded} {width} {height} {cacheBust}
# EMBED_SNAPSHOT_TEMPLATE=
# Live template placeholders: {url} {urlEncoded}
# EMBED_LIVE_TEMPLATE=
# HYPERBEAM_API_KEY=
