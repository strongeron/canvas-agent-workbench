#!/usr/bin/env node

import path from 'node:path'

import {
  bootstrapCanvasAgentSession,
  buildCanvasContextSummary,
  clearCanvasAgentAttachedContext,
  captureWorkspaceScreenshot,
  createProjectCanvasFile,
  deleteProjectCanvasFile,
  duplicateProjectCanvasFile,
  enqueueAgentNativeWorkspaceOperation,
  enqueueCanvasAgentOperation,
  fail,
  formatCanvasAgentShellExports,
  getDefaultCanvasAgentServerUrl,
  getCanvasAgentContextFromEnv,
  listProjectCanvasFiles,
  moveProjectCanvasFile,
  openProjectCanvasFile,
  readAgentNativeWorkspaceDebug,
  readAgentNativeManifest,
  readAgentNativeWorkspaceEvents,
  readAgentNativeWorkspaceManifest,
  readColorAuditExportPreview,
  readColorAuditState,
  readNodeCatalogState,
  readSystemCanvasState,
  parseCanvasAgentIds,
  readCanvasAgentDebug,
  readCanvasAgentPrimitives,
  readCanvasAgentSelection,
  readCanvasAgentState,
  readCanvasAgentTranscript,
  readJsonPayload,
  resolveCanvasAgentContextFilePath,
  saveProjectCanvasFile,
  updateProjectCanvasFileMetadata,
  writeCanvasAgentAttachedContext,
  writeJson,
} from './canvas-agent-runtime.mjs'
import {
  createArtboardItem,
  createClearCanvasOperation,
  createCreateItemOperation,
  createDeleteItemsOperation,
  createPrimitiveCanvasItem,
  createSelectItemsOperation,
  createUpdateItemOperation,
  exportCanvasBoard,
} from '../utils/canvasAgentOperations.mjs'

const HELP = `canvas-agent

Usage:
  bin/canvas-agent help
  bin/canvas-agent attach --project <project-id> [--surface <surface-id>] [--agent <agent-id>] [--server <url>] [--json|--shell]
  bin/canvas-agent detach
  bin/canvas-agent workspace-manifest
  bin/canvas-agent workspace-events <workspace-id> [limit]
  bin/canvas-agent workspace-debug <workspace-id> [limit]
  bin/canvas-agent surface-manifest <workspace-id>
  bin/canvas-agent canvas-files [surface]
  bin/canvas-agent open-canvas-file <path>
  bin/canvas-agent create-canvas-file <json|@file|->
  bin/canvas-agent save-canvas-file <path> <json|@file|->
  bin/canvas-agent update-canvas-file-metadata <path> <json|@file|->
  bin/canvas-agent move-canvas-file <path> <json|@file|->
  bin/canvas-agent duplicate-canvas-file <path> <json|@file|->
  bin/canvas-agent delete-canvas-file <path>
  bin/canvas-agent color-audit-state
  bin/canvas-agent color-audit-export
  bin/canvas-agent node-catalog-state
  bin/canvas-agent generate-template <json|@file|->
  bin/canvas-agent create-color-node <json|@file|->
  bin/canvas-agent update-color-node <node-id> <json|@file|->
  bin/canvas-agent delete-color-node <node-id>
  bin/canvas-agent create-color-edge <json|@file|->
  bin/canvas-agent update-color-edge <edge-id> <json|@file|->
  bin/canvas-agent delete-color-edge <edge-id>
  bin/canvas-agent system-canvas-state
  bin/canvas-agent update-system-scale-config <json|@file|->
  bin/canvas-agent set-system-view <system|colors|type|layout|primitives|standards|all>
  bin/canvas-agent generate-scale-graph
  bin/canvas-agent apply-scale-vars
  bin/canvas-agent create-system-node <json|@file|->
  bin/canvas-agent update-system-node <node-id> <json|@file|->
  bin/canvas-agent delete-system-node <node-id>
  bin/canvas-agent create-system-edge <json|@file|->
  bin/canvas-agent update-system-edge <edge-id> <json|@file|->
  bin/canvas-agent delete-system-edge <edge-id>
  bin/canvas-agent screenshot <workspace-id> [desktop|mobile]
  bin/canvas-agent state
  bin/canvas-agent context
  bin/canvas-agent selection
  bin/canvas-agent primitives
  bin/canvas-agent primitive <primitive-id>
  bin/canvas-agent create-artboard <json|@file|->
  bin/canvas-agent create-primitive-item <json|@file|->
  bin/canvas-agent create-item <json|@file|->
  bin/canvas-agent update-item <item-id> <json|@file|->
  bin/canvas-agent delete-items <id[,id...]>
  bin/canvas-agent select-items <id[,id...]>
  bin/canvas-agent clear-canvas
  bin/canvas-agent export-board <artboard-id> [format] [component-name]
  bin/canvas-agent transcript
  bin/canvas-agent debug

Payload formats:
  <json>       Inline JSON string
  @file        Read JSON from file path
  -            Read JSON from stdin

Environment:
  After "attach", commands use .canvas-agent/attached-session.json automatically.
  Env vars still override the attached context when set.
  CANVAS_AGENT_SESSION_DIR  Required only when not using attach
  CANVAS_AGENT_PROJECT_ID   Required only when not using attach
  CANVAS_AGENT_SESSION_ID   Required only when not using attach
  CANVAS_AGENT_SERVER_URL   Optional dev server URL for agent-native resources
`

function parseOptionArgs(inputArgs) {
  const options = {}
  const positionals = []

  for (let index = 0; index < inputArgs.length; index += 1) {
    const part = inputArgs[index]
    if (!part.startsWith('--')) {
      positionals.push(part)
      continue
    }

    const [rawKey, inlineValue] = part.slice(2).split('=')
    const key = rawKey?.trim()
    if (!key) continue

    if (typeof inlineValue === 'string') {
      options[key] = inlineValue
      continue
    }

    const next = inputArgs[index + 1]
    if (next && !next.startsWith('--')) {
      options[key] = next
      index += 1
      continue
    }

    options[key] = true
  }

  return { options, positionals }
}

function printAttachSummary(payload) {
  const lines = [
    `Attached canvas-agent session ${payload.session.id} (${payload.reused ? 'reused' : 'created'})`,
    `Project: ${payload.context.projectId}`,
    `Agent: ${payload.session.agentLabel}`,
    `Server: ${payload.context.serverUrl}`,
    `Context file: ${payload.contextFilePath}`,
  ]
  if (payload.surfaceId) {
    lines.push(`Surface: ${payload.surfaceId}`)
  }
  lines.push('')
  lines.push('Next commands:')
  lines.push('  bin/canvas-agent workspace-manifest')
  if (payload.surfaceId === 'color-audit') {
    lines.push('  bin/canvas-agent color-audit-state')
    lines.push('  bin/canvas-agent color-audit-export')
  } else if (payload.surfaceId === 'system-canvas') {
    lines.push('  bin/canvas-agent system-canvas-state')
    lines.push('  bin/canvas-agent generate-scale-graph')
    lines.push('  bin/canvas-agent apply-scale-vars')
  } else if (payload.surfaceId === 'node-catalog') {
    lines.push('  bin/canvas-agent node-catalog-state')
  } else {
    lines.push('  bin/canvas-agent state')
    lines.push('  bin/canvas-agent color-audit-state')
    lines.push('  bin/canvas-agent system-canvas-state')
  }
  process.stdout.write(`${lines.join('\n')}\n`)
}

function getCliContextFilePath() {
  return process.env.CANVAS_AGENT_CONTEXT_FILE?.trim() || resolveCanvasAgentContextFilePath(process.cwd())
}

async function main() {
  const [command = 'help', ...args] = process.argv.slice(2)

  if (command === 'help' || command === '--help' || command === '-h') {
    process.stdout.write(`${HELP}\n`)
    return
  }

  if (command === 'attach') {
    const { options } = parseOptionArgs(args)
    const projectId = typeof options.project === 'string' ? options.project.trim() : ''
    if (!projectId) fail('attach requires --project <project-id>.')

    const serverUrl =
      (typeof options.server === 'string' && options.server.trim()) ||
      getDefaultCanvasAgentServerUrl()
    const surfaceId =
      typeof options.surface === 'string' && options.surface.trim() ? options.surface.trim() : null
    const bootstrap = await bootstrapCanvasAgentSession({
      projectId,
      agentId:
        typeof options.agent === 'string' && options.agent.trim() ? options.agent.trim() : 'codex',
      cwd: typeof options.cwd === 'string' && options.cwd.trim() ? path.resolve(options.cwd) : process.cwd(),
      title: typeof options.title === 'string' && options.title.trim() ? options.title.trim() : undefined,
      serverUrl,
      surfaceId: surfaceId || undefined,
      reuseSession: options.new ? false : true,
    })

    if (!bootstrap?.context || !bootstrap?.session) {
      fail('Canvas agent bootstrap did not return session context.')
    }

    const contextFilePath = getCliContextFilePath()
    await writeCanvasAgentAttachedContext(bootstrap.context, contextFilePath)
    const payload = {
      ...bootstrap,
      surfaceId,
      contextFilePath,
    }

    if (options.shell) {
      process.stdout.write(`${formatCanvasAgentShellExports(bootstrap.context)}\n`)
      return
    }

    if (options.json) {
      writeJson(payload)
      return
    }

    printAttachSummary(payload)
    return
  }

  if (command === 'detach') {
    const contextFilePath = getCliContextFilePath()
    await clearCanvasAgentAttachedContext(contextFilePath)
    writeJson({
      ok: true,
      detached: true,
      contextFilePath,
    })
    return
  }

  const context = getCanvasAgentContextFromEnv()

  switch (command) {
    case 'workspace-manifest': {
      writeJson(await readAgentNativeManifest(context))
      return
    }
    case 'workspace-events': {
      const workspaceId = args[0]?.trim()
      if (!workspaceId) fail('workspace-events requires a workspace id.')
      const limit = args[1] ? Number.parseInt(args[1], 10) : undefined
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
          ? context.colorAuditWorkspaceKey
          : workspaceId === 'system-canvas'
            ? context.systemCanvasWorkspaceKey
            : workspaceId === 'node-catalog'
              ? context.nodeCatalogWorkspaceKey
              : undefined
      writeJson(
        await readAgentNativeWorkspaceEvents(context, workspaceId, workspaceKey, {
          limit,
        })
      )
      return
    }
    case 'workspace-debug': {
      const workspaceId = args[0]?.trim()
      if (!workspaceId) fail('workspace-debug requires a workspace id.')
      const limit = args[1] ? Number.parseInt(args[1], 10) : undefined
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
            ? context.colorAuditWorkspaceKey
            : workspaceId === 'system-canvas'
              ? context.systemCanvasWorkspaceKey
              : workspaceId === 'node-catalog'
                ? context.nodeCatalogWorkspaceKey
                : undefined
      writeJson(await readAgentNativeWorkspaceDebug(context, workspaceId, workspaceKey, { limit }))
      return
    }
    case 'surface-manifest': {
      const workspaceId = args[0]?.trim()
      if (!workspaceId) fail('surface-manifest requires a workspace id.')
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
            ? context.colorAuditWorkspaceKey
            : workspaceId === 'system-canvas'
              ? context.systemCanvasWorkspaceKey
              : workspaceId === 'node-catalog'
                ? context.nodeCatalogWorkspaceKey
                : undefined
      writeJson(await readAgentNativeWorkspaceManifest(context, workspaceId, workspaceKey))
      return
    }
    case 'canvas-files': {
      const surface = args[0]?.trim()
      writeJson(await listProjectCanvasFiles(context, { surface }))
      return
    }
    case 'open-canvas-file': {
      const canvasPath = args[0]?.trim()
      if (!canvasPath) fail('open-canvas-file requires a file path.')
      writeJson(await openProjectCanvasFile(context, canvasPath))
      return
    }
    case 'create-canvas-file': {
      const payload = await readJsonPayload(args[0])
      if (!payload || typeof payload !== 'object') {
        fail('create-canvas-file requires a JSON object payload.')
      }
      writeJson(await createProjectCanvasFile(context, payload))
      return
    }
    case 'save-canvas-file': {
      const [canvasPath, payloadRef] = args
      if (!canvasPath?.trim()) fail('save-canvas-file requires a file path.')
      const payload = await readJsonPayload(payloadRef)
      if (!payload || typeof payload !== 'object' || !payload.document) {
        fail('save-canvas-file requires a JSON payload with document.')
      }
      writeJson(
        await saveProjectCanvasFile(
          context,
          canvasPath.trim(),
          payload.document,
          Array.isArray(payload.assets) ? payload.assets : undefined
        )
      )
      return
    }
    case 'update-canvas-file-metadata': {
      const [canvasPath, payloadRef] = args
      if (!canvasPath?.trim()) fail('update-canvas-file-metadata requires a file path.')
      const payload = await readJsonPayload(payloadRef)
      if (!payload || typeof payload !== 'object') {
        fail('update-canvas-file-metadata requires a JSON object payload.')
      }
      writeJson(await updateProjectCanvasFileMetadata(context, canvasPath.trim(), payload))
      return
    }
    case 'move-canvas-file': {
      const [canvasPath, payloadRef] = args
      if (!canvasPath?.trim()) fail('move-canvas-file requires a file path.')
      const payload = await readJsonPayload(payloadRef)
      if (!payload || typeof payload !== 'object') {
        fail('move-canvas-file requires a JSON object payload.')
      }
      writeJson(await moveProjectCanvasFile(context, canvasPath.trim(), payload))
      return
    }
    case 'duplicate-canvas-file': {
      const [canvasPath, payloadRef] = args
      if (!canvasPath?.trim()) fail('duplicate-canvas-file requires a file path.')
      const payload = await readJsonPayload(payloadRef)
      if (!payload || typeof payload !== 'object') {
        fail('duplicate-canvas-file requires a JSON object payload.')
      }
      writeJson(await duplicateProjectCanvasFile(context, canvasPath.trim(), payload))
      return
    }
    case 'delete-canvas-file': {
      const canvasPath = args[0]?.trim()
      if (!canvasPath) fail('delete-canvas-file requires a file path.')
      writeJson(await deleteProjectCanvasFile(context, canvasPath))
      return
    }
    case 'color-audit-state': {
      writeJson(await readColorAuditState(context))
      return
    }
    case 'color-audit-export': {
      writeJson(await readColorAuditExportPreview(context))
      return
    }
    case 'node-catalog-state': {
      writeJson(await readNodeCatalogState(context))
      return
    }
    case 'generate-template': {
      const payload = await readJsonPayload(args[0])
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'generate-template',
            templateKitId: payload?.templateKitId,
            brandColor: payload?.brandColor,
            accentColor: payload?.accentColor,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-color-node': {
      const payload = await readJsonPayload(args[0])
      if (!payload || typeof payload !== 'object') fail('create-color-node requires a JSON object payload.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'create-node',
            node: payload.node ?? payload,
            select: typeof payload.select === 'boolean' ? payload.select : undefined,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'update-color-node': {
      const [nodeId, payloadRef] = args
      if (!nodeId?.trim()) fail('update-color-node requires a node id.')
      const patch = await readJsonPayload(payloadRef)
      if (!patch || typeof patch !== 'object') fail('update-color-node requires a JSON object patch.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'update-node',
            nodeId: nodeId.trim(),
            patch,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'delete-color-node': {
      const nodeId = args[0]?.trim()
      if (!nodeId) fail('delete-color-node requires a node id.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'delete-node',
            nodeId,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-color-edge': {
      const payload = await readJsonPayload(args[0])
      if (!payload || typeof payload !== 'object') fail('create-color-edge requires a JSON object payload.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'create-edge',
            edge: payload.edge ?? payload,
            select: typeof payload.select === 'boolean' ? payload.select : undefined,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'update-color-edge': {
      const [edgeId, payloadRef] = args
      if (!edgeId?.trim()) fail('update-color-edge requires an edge id.')
      const patch = await readJsonPayload(payloadRef)
      if (!patch || typeof patch !== 'object') fail('update-color-edge requires a JSON object patch.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'update-edge',
            edgeId: edgeId.trim(),
            patch,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'delete-color-edge': {
      const edgeId = args[0]?.trim()
      if (!edgeId) fail('delete-color-edge requires an edge id.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'color-audit',
          context.colorAuditWorkspaceKey,
          {
            type: 'delete-edge',
            edgeId,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'system-canvas-state': {
      writeJson(await readSystemCanvasState(context))
      return
    }
    case 'update-system-scale-config': {
      const patch = await readJsonPayload(args[0])
      if (!patch || typeof patch !== 'object') {
        fail('update-system-scale-config requires a JSON object patch.')
      }
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'update-scale-config',
            patch,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'set-system-view': {
      const viewMode = args[0]?.trim()
      if (!viewMode) fail('set-system-view requires a view mode.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'set-view-mode',
            viewMode,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'generate-scale-graph': {
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'generate-scale-graph',
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'apply-scale-vars': {
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'apply-scale-vars',
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-system-node': {
      const payload = await readJsonPayload(args[0])
      if (!payload || typeof payload !== 'object') fail('create-system-node requires a JSON object payload.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'create-node',
            node: payload.node ?? payload,
            select: typeof payload.select === 'boolean' ? payload.select : undefined,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'update-system-node': {
      const [nodeId, payloadRef] = args
      if (!nodeId?.trim()) fail('update-system-node requires a node id.')
      const patch = await readJsonPayload(payloadRef)
      if (!patch || typeof patch !== 'object') fail('update-system-node requires a JSON object patch.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'update-node',
            nodeId: nodeId.trim(),
            patch,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'delete-system-node': {
      const nodeId = args[0]?.trim()
      if (!nodeId) fail('delete-system-node requires a node id.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'delete-node',
            nodeId,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-system-edge': {
      const payload = await readJsonPayload(args[0])
      if (!payload || typeof payload !== 'object') fail('create-system-edge requires a JSON object payload.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'create-edge',
            edge: payload.edge ?? payload,
            select: typeof payload.select === 'boolean' ? payload.select : undefined,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'update-system-edge': {
      const [edgeId, payloadRef] = args
      if (!edgeId?.trim()) fail('update-system-edge requires an edge id.')
      const patch = await readJsonPayload(payloadRef)
      if (!patch || typeof patch !== 'object') fail('update-system-edge requires a JSON object patch.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'update-edge',
            edgeId: edgeId.trim(),
            patch,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'delete-system-edge': {
      const edgeId = args[0]?.trim()
      if (!edgeId) fail('delete-system-edge requires an edge id.')
      writeJson(
        await enqueueAgentNativeWorkspaceOperation(
          context,
          'system-canvas',
          context.systemCanvasWorkspaceKey,
          {
            type: 'delete-edge',
            edgeId,
          },
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'screenshot': {
      const workspaceId = args[0]?.trim()
      if (!workspaceId) fail('screenshot requires a workspace id.')
      writeJson(await captureWorkspaceScreenshot(context, workspaceId, args[1]?.trim() || 'desktop'))
      return
    }
    case 'state': {
      writeJson(await readCanvasAgentState(context))
      return
    }
    case 'context': {
      const [state, primitives] = await Promise.all([
        readCanvasAgentState(context),
        readCanvasAgentPrimitives(context),
      ])
      writeJson(buildCanvasContextSummary(state, primitives))
      return
    }
    case 'selection': {
      writeJson(await readCanvasAgentSelection(context))
      return
    }
    case 'primitives': {
      writeJson(await readCanvasAgentPrimitives(context))
      return
    }
    case 'primitive': {
      const primitiveId = args[0]?.trim()
      if (!primitiveId) fail('primitive requires a primitive id.')
      const primitives = await readCanvasAgentPrimitives(context)
      const primitive = primitives.find((entry) => entry.primitiveId === primitiveId || entry.entryId === primitiveId)
      if (!primitive) fail(`Unknown primitive: ${primitiveId}`)
      writeJson(primitive)
      return
    }
    case 'create-artboard': {
      const payload = await readJsonPayload(args[0])
      const state = await readCanvasAgentState(context)
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'create-artboard',
          createCreateItemOperation(createArtboardItem(state, payload), payload?.select !== false),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-primitive-item': {
      const payload = await readJsonPayload(args[0])
      const primitiveId =
        typeof payload?.primitiveId === 'string' && payload.primitiveId.trim()
          ? payload.primitiveId.trim()
          : ''
      if (!primitiveId) fail('create-primitive-item requires primitiveId in the payload.')
      const [state, primitives] = await Promise.all([
        readCanvasAgentState(context),
        readCanvasAgentPrimitives(context),
      ])
      const primitive = primitives.find(
        (entry) => entry.primitiveId === primitiveId || entry.entryId === primitiveId
      )
      if (!primitive) fail(`Unknown primitive: ${primitiveId}`)
      const item = createPrimitiveCanvasItem(state, primitive, payload)
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'create-primitive-item',
          createCreateItemOperation(item, payload?.select !== false),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'create-item': {
      const item = await readJsonPayload(args[0])
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'create-item',
          createCreateItemOperation(item, true),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'update-item': {
      const [itemId, payloadRef] = args
      if (!itemId) fail('update-item requires an item id.')
      const updates = await readJsonPayload(payloadRef)
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'update-item',
          createUpdateItemOperation(itemId, updates),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'delete-items': {
      const ids = parseCanvasAgentIds(args[0])
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'delete-items',
          createDeleteItemsOperation(ids),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'select-items': {
      const ids = parseCanvasAgentIds(args[0])
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'select-items',
          createSelectItemsOperation(ids),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'clear-canvas': {
      writeJson(
        await enqueueCanvasAgentOperation(
          context,
          'clear-canvas',
          createClearCanvasOperation(),
          { source: 'canvas-agent-cli' }
        )
      )
      return
    }
    case 'export-board': {
      const [artboardId, format, componentName] = args
      if (!artboardId?.trim()) fail('export-board requires an artboard id.')
      const [state, primitives] = await Promise.all([
        readCanvasAgentState(context),
        readCanvasAgentPrimitives(context),
      ])
      writeJson(
        exportCanvasBoard({
          artboardId: artboardId.trim(),
          format: format?.trim() || undefined,
          componentName: componentName?.trim() || undefined,
          state,
          primitives,
        })
      )
      return
    }
    case 'transcript': {
      writeJson(await readCanvasAgentTranscript(context))
      return
    }
    case 'debug': {
      writeJson(await readCanvasAgentDebug(context))
      return
    }
    default:
      fail(`Unknown command: ${command}`)
  }
}

main().catch((error) => {
  fail(error instanceof Error ? error.message : 'Unexpected canvas-agent failure.')
})
