const context = getCanvasAgentContextFromEnv()
const parser = createMessageParser(handleMessage)
process.stdin.on('data', (chunk) => parser.push(chunk))
process.stdin.on('end', () => process.exit(0))

function positionSchema() {
  return {
    type: 'object',
    properties: {
      x: { type: 'number' },
      y: { type: 'number' },
    },
    required: ['x', 'y'],
    additionalProperties: false,
  }
}

function sizeSchema() {
  return {
    type: 'object',
    properties: {
      width: { type: 'number' },
      height: { type: 'number' },
    },
    required: ['width', 'height'],
    additionalProperties: false,
  }
}

function createMessageParser(onMessage) {
  let buffer = Buffer.alloc(0)
  let expectedLength = null

  return {
    push(chunk) {
      buffer = Buffer.concat([buffer, Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk)])

      while (true) {
        if (expectedLength == null) {
          const headerEnd = buffer.indexOf('\r\n\r\n')
          if (headerEnd < 0) return

          const headerBlock = buffer.slice(0, headerEnd).toString('utf8')
          buffer = buffer.slice(headerEnd + 4)
          const headers = parseHeaders(headerBlock)
          const contentLength = Number.parseInt(headers['content-length'] || '', 10)
          if (!Number.isFinite(contentLength) || contentLength < 0) {
            process.stderr.write('[canvas-mcp] Missing or invalid Content-Length header.\n')
            expectedLength = null
            continue
          }
          expectedLength = contentLength
        }

        if (buffer.length < expectedLength) return

        const body = buffer.slice(0, expectedLength).toString('utf8')
        buffer = buffer.slice(expectedLength)
        expectedLength = null

        try {
          void onMessage(JSON.parse(body))
        } catch (error) {
          process.stderr.write(`[canvas-mcp] Failed to parse JSON message: ${error instanceof Error ? error.message : String(error)}\n`)
        }
      }
    },
  }
}

function parseHeaders(block) {
  return block.split('\r\n').reduce((acc, line) => {
    const index = line.indexOf(':')
    if (index < 0) return acc
    const key = line.slice(0, index).trim().toLowerCase()
    const value = line.slice(index + 1).trim()
    if (key) acc[key] = value
    return acc
  }, {})
}

async function handleMessage(message) {
  if (!message || typeof message !== 'object') return
  const { id, method, params } = message
  if (!method || typeof method !== 'string') return

  try {
    if (method === 'initialize') {
      protocolVersion =
        typeof params?.protocolVersion === 'string' && params.protocolVersion.trim()
          ? params.protocolVersion.trim()
          : FALLBACK_PROTOCOL_VERSION
      return sendResponse(id, {
        protocolVersion,
        capabilities: {
          tools: {
            listChanged: false,
          },
          resources: {
            subscribe: false,
            listChanged: false,
          },
          prompts: {
            listChanged: false,
          },
        },
        serverInfo: SERVER_INFO,
      })
    }

    if (method === 'notifications/initialized') return
    if (method === 'ping') return sendResponse(id, {})
    if (method === 'tools/list') return sendResponse(id, { tools: TOOL_DEFINITIONS })
    if (method === 'resources/list') return sendResponse(id, { resources: RESOURCE_DEFINITIONS })
    if (method === 'resources/read') {
      const uri = typeof params?.uri === 'string' ? params.uri : ''
      return sendResponse(id, await readResource(uri))
    }
    if (method === 'prompts/list') return sendResponse(id, { prompts: PROMPT_DEFINITIONS })
    if (method === 'prompts/get') {
      const name = typeof params?.name === 'string' ? params.name : ''
      const args = params?.arguments && typeof params.arguments === 'object' ? params.arguments : {}
      return sendResponse(id, buildPrompt(name, args))
    }

    if (method === 'tools/call') {
      const name = typeof params?.name === 'string' ? params.name : ''
      const args = params?.arguments && typeof params.arguments === 'object' ? params.arguments : {}
      return sendResponse(id, await callTool(name, args))
    }

    return sendError(id, -32601, `Method not found: ${method}`)
  } catch (error) {
    return sendError(id, -32000, error instanceof Error ? error.message : 'Canvas MCP server failed.')
  }
}

async function callTool(name, args) {
  switch (name) {
    case 'get_workspace_manifest':
      return asToolResult(await readAgentNativeManifest(context))
    case 'get_surface_manifest': {
      const workspaceId = normalizeString(args.workspaceId)
      if (!workspaceId) return asToolError('workspaceId is required.')
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
            ? context.colorAuditWorkspaceKey
            : workspaceId === 'system-canvas'
              ? context.systemCanvasWorkspaceKey
              : workspaceId === 'node-catalog'
                ? context.nodeCatalogWorkspaceKey
                : undefined
      return asToolResult(await readAgentNativeWorkspaceManifest(context, workspaceId, workspaceKey))
    }
    case 'list_canvas_files':
      return asToolResult(await listProjectCanvasFiles(context, { surface: normalizeString(args.surface) || undefined }))
    case 'open_canvas_file': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      return asToolResult(await openProjectCanvasFile(context, canvasPath))
    }
    case 'create_canvas_file': {
      const title = normalizeString(args.title)
      if (!title) return asToolError('title is required.')
      return asToolResult(
        await createProjectCanvasFile(context, {
          title,
          folder: normalizeString(args.folder) || undefined,
          surface: normalizeString(args.surface) || undefined,
          document: args.document,
          view: args.view,
          assets: Array.isArray(args.assets) ? args.assets : undefined,
        })
      )
    }
    case 'save_canvas_file': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      if (!args.document || typeof args.document !== 'object') {
        return asToolError('document is required.')
      }
      return asToolResult(
        await saveProjectCanvasFile(
          context,
          canvasPath,
          args.document,
          Array.isArray(args.assets) ? args.assets : undefined
        )
      )
    }
    case 'update_canvas_file_metadata': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      return asToolResult(
        await updateProjectCanvasFileMetadata(context, canvasPath, {
          title: normalizeString(args.title) || undefined,
          tags: Array.isArray(args.tags) ? args.tags : undefined,
          favorite: typeof args.favorite === 'boolean' ? args.favorite : undefined,
          archived: typeof args.archived === 'boolean' ? args.archived : undefined,
        })
      )
    }
    case 'move_canvas_file': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      return asToolResult(
        await moveProjectCanvasFile(context, canvasPath, {
          nextPath: normalizeString(args.nextPath) || undefined,
          title: normalizeString(args.title) || undefined,
          folder: normalizeString(args.folder) || undefined,
        })
      )
    }
    case 'duplicate_canvas_file': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      return asToolResult(
        await duplicateProjectCanvasFile(context, canvasPath, {
          nextPath: normalizeString(args.nextPath) || undefined,
          title: normalizeString(args.title) || undefined,
          folder: normalizeString(args.folder) || undefined,
        })
      )
    }
    case 'delete_canvas_file': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      return asToolResult(await deleteProjectCanvasFile(context, canvasPath))
    }
    case 'import_html_bundle': {
      const canvasPath = normalizeString(args.path)
      if (!canvasPath) return asToolError('path is required.')
      const bundle = args.bundle && typeof args.bundle === 'object' ? args.bundle : null
      if (!bundle) return asToolError('bundle is required.')

      const htmlBundle = await importProjectCanvasHtmlBundle(context, canvasPath, bundle)
      if (args.createItem === false) {
        return asToolResult({ htmlBundle })
      }

      try {
        const state = await readCanvasAgentState(context)
        const itemArgs = args.item && typeof args.item === 'object' ? args.item : {}
        const item = createHtmlCanvasItem(state, {
          src: htmlBundle?.entryUrl,
          title: normalizeString(itemArgs.title) || normalizeString(bundle.title) || undefined,
          sandbox: normalizeString(itemArgs.sandbox) || undefined,
          background: normalizeString(itemArgs.background) || undefined,
          parentId: normalizeString(itemArgs.parentId) || undefined,
          position: itemArgs.position,
          size: itemArgs.size,
          entryAsset: htmlBundle?.entryAsset,
          sourcePath: normalizeString(bundle.directoryPath) || undefined,
          sourceImportedAt: htmlBundle?.importedAt,
        })
        const result = await enqueueCanvasAgentOperation(
          context,
          'import_html_bundle',
          createCreateItemOperation(item, args.select !== false),
          {
            source: 'canvas-agent-mcp',
          }
        )
        if (!result.ok) {
          return asToolError(result.error || 'Failed to create html item.')
        }
        return asToolResult({
          htmlBundle,
          item,
          result: {
            ...result,
            canvasPath,
            entryAsset: htmlBundle?.entryAsset || null,
          },
        })
      } catch (error) {
        return asToolError(error instanceof Error ? error.message : 'Failed to create html item.')
      }
    }
    case 'get_workspace_events': {
      const workspaceId = normalizeString(args.workspaceId)
      if (!workspaceId) return asToolError('workspaceId is required.')
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
          ? context.colorAuditWorkspaceKey
          : workspaceId === 'system-canvas'
            ? context.systemCanvasWorkspaceKey
            : workspaceId === 'node-catalog'
              ? context.nodeCatalogWorkspaceKey
              : undefined
      return asToolResult(
        await readAgentNativeWorkspaceEvents(context, workspaceId, workspaceKey, {
          limit: Number.isFinite(args.limit) ? Number(args.limit) : undefined,
        })
      )
    }
    case 'get_workspace_debug': {
      const workspaceId = normalizeString(args.workspaceId)
      if (!workspaceId) return asToolError('workspaceId is required.')
      const workspaceKey =
        workspaceId === 'canvas'
          ? context.canvasWorkspaceKey
          : workspaceId === 'color-audit'
            ? context.colorAuditWorkspaceKey
            : workspaceId === 'system-canvas'
              ? context.systemCanvasWorkspaceKey
              : workspaceId === 'node-catalog'
                ? context.nodeCatalogWorkspaceKey
                : undefined
      return asToolResult(
        await readAgentNativeWorkspaceDebug(context, workspaceId, workspaceKey, {
          limit: Number.isFinite(args.limit) ? Number(args.limit) : undefined,
        })
      )
    }
    case 'get_color_audit_state':
      return asToolResult(await readColorAuditState(context))
    case 'get_color_audit_export_preview':
      return asToolResult(await readColorAuditExportPreview(context))
    case 'generate_template':
      return runGenerateTemplate(args)
    case 'create_color_node':
      return runCreateColorNode(args)
    case 'update_color_node':
      return runUpdateColorNode(args)
    case 'delete_color_node':
      return runDeleteColorNode(args)
    case 'create_color_edge':
      return runCreateColorEdge(args)
    case 'update_color_edge':
      return runUpdateColorEdge(args)
    case 'delete_color_edge':
      return runDeleteColorEdge(args)
    case 'get_system_canvas_state':
      return asToolResult(await readSystemCanvasState(context))
    case 'update_system_scale_config':
      return runUpdateSystemScaleConfig(args)
    case 'set_system_canvas_view':
      return runSetSystemCanvasView(args)
    case 'generate_scale_graph':
      return runGenerateScaleGraph()
    case 'apply_scale_vars':
      return runApplyScaleVars()
    case 'create_system_node':
      return runCreateSystemNode(args)
    case 'update_system_node':
      return runUpdateSystemNode(args)
    case 'delete_system_node':
      return runDeleteSystemNode(args)
    case 'create_system_edge':
      return runCreateSystemEdge(args)
    case 'update_system_edge':
      return runUpdateSystemEdge(args)
    case 'delete_system_edge':
      return runDeleteSystemEdge(args)
    case 'get_node_catalog_state':
      return asToolResult(await readNodeCatalogState(context))
    case 'capture_workspace_screenshot': {
      const workspaceId = normalizeString(args.workspaceId)
      if (!workspaceId) return asToolError('workspaceId is required.')
      return asToolResult(await captureWorkspaceScreenshot(context, workspaceId, normalizeString(args.target) || 'desktop'))
    }
    case 'get_canvas_context': {
      const [state, primitives] = await Promise.all([
        readCanvasAgentState(context),
        readCanvasAgentPrimitives(context),
      ])
      return asToolResult(buildCanvasContextSummary(state, primitives))
    }
    case 'get_canvas_state':
      return asToolResult(await readCanvasAgentState(context))
    case 'get_canvas_selection': {
      const [state, primitives, selectedIds] = await Promise.all([
        readCanvasAgentState(context),
        readCanvasAgentPrimitives(context),
        readCanvasAgentSelection(context),
      ])
      const summary = buildCanvasContextSummary(state, primitives)
      const itemMap = flattenCanvasSummaryItems(summary)
      return asToolResult({
        selectedIds,
        items: selectedIds.map((id) => itemMap.get(id)).filter(Boolean),
      })
    }
    case 'list_primitives': {
      const primitives = await readCanvasAgentPrimitives(context)
      const family = normalizeString(args.family)
      const level = normalizeString(args.level)
      const exportable = typeof args.exportable === 'boolean' ? args.exportable : null
      return asToolResult(
        primitives.filter((primitive) => {
          if (family && primitive.family !== family) return false
          if (level && primitive.level !== level) return false
          if (exportable != null && Boolean(primitive.exportable !== false) !== exportable) return false
          return true
        })
      )
    }
    case 'get_primitive': {
      const primitive = await getPrimitiveById(normalizeString(args.primitiveId))
      if (!primitive) return asToolError(`Primitive not found: ${args.primitiveId || ''}`)
      return asToolResult(primitive)
    }
    case 'create_artboard':
      return runCreateArtboard(args)
    case 'create_primitive_item':
      return runCreatePrimitiveItem(args)
    case 'create_item':
      return runCreateItem(args)
    case 'update_item':
      return runUpdateItem(args)
    case 'delete_items':
      return runDeleteItems(args)
    case 'select_items':
      return runSelectItems(args)
    case 'clear_canvas':
      return runClearCanvas()
    case 'export_board':
      return runExportBoard(args)
    default:
      return asToolError(`Unknown tool: ${name}`)
  }
}

async function readResource(uri) {
  switch (uri) {
    case 'workspace://manifest':
      return asResourceResult(uri, await readAgentNativeManifest(context))
    case 'workspace://project/canvases/index':
      return asResourceResult(uri, await listProjectCanvasFiles(context))
    case 'workspace://surface/canvas/state':
      return asResourceResult(uri, await readCanvasAgentState(context))
    case 'workspace://surface/canvas/selection':
      return asResourceResult(uri, await readCanvasAgentSelection(context))
    case 'workspace://surface/canvas/primitives':
      return asResourceResult(uri, await readCanvasAgentPrimitives(context))
    case 'workspace://surface/canvas/events':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceEvents(context, 'canvas', context.canvasWorkspaceKey)
      )
    case 'workspace://surface/canvas/debug':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceDebug(context, 'canvas', context.canvasWorkspaceKey)
      )
    case 'workspace://surface/canvas/viewport/screenshot':
      return asResourceResult(uri, await captureWorkspaceScreenshot(context, 'canvas'))
    case 'workspace://surface/color-audit/manifest':
      return asResourceResult(uri, await readAgentNativeWorkspaceManifest(context, 'color-audit'))
    case 'workspace://surface/color-audit/state':
      return asResourceResult(uri, await readColorAuditState(context))
    case 'workspace://surface/color-audit/export-preview':
      return asResourceResult(uri, await readColorAuditExportPreview(context))
    case 'workspace://surface/color-audit/events':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceEvents(context, 'color-audit', context.colorAuditWorkspaceKey)
      )
    case 'workspace://surface/color-audit/debug':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceDebug(context, 'color-audit', context.colorAuditWorkspaceKey)
      )
    case 'workspace://surface/color-audit/viewport/screenshot':
      return asResourceResult(uri, await captureWorkspaceScreenshot(context, 'color-audit'))
    case 'workspace://surface/system-canvas/manifest':
      return asResourceResult(uri, await readAgentNativeWorkspaceManifest(context, 'system-canvas'))
    case 'workspace://surface/system-canvas/state':
      return asResourceResult(uri, await readSystemCanvasState(context))
    case 'workspace://surface/system-canvas/events':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceEvents(context, 'system-canvas', context.systemCanvasWorkspaceKey)
      )
    case 'workspace://surface/system-canvas/debug':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceDebug(context, 'system-canvas', context.systemCanvasWorkspaceKey)
      )
    case 'workspace://surface/system-canvas/viewport/screenshot':
      return asResourceResult(uri, await captureWorkspaceScreenshot(context, 'system-canvas'))
    case 'workspace://surface/node-catalog/state':
      return asResourceResult(uri, await readNodeCatalogState(context))
    case 'workspace://surface/node-catalog/manifest':
      return asResourceResult(uri, await readAgentNativeWorkspaceManifest(context, 'node-catalog'))
    case 'workspace://surface/node-catalog/sections': {
      const state = await readNodeCatalogState(context)
      return asResourceResult(uri, {
        workspaceSections: Array.isArray(state?.workspaceSections) ? state.workspaceSections : [],
        nodeSections: Array.isArray(state?.nodeSections) ? state.nodeSections : [],
      })
    }
    case 'workspace://surface/node-catalog/events':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceEvents(context, 'node-catalog', context.nodeCatalogWorkspaceKey)
      )
    case 'workspace://surface/node-catalog/debug':
      return asResourceResult(
        uri,
        await readAgentNativeWorkspaceDebug(context, 'node-catalog', context.nodeCatalogWorkspaceKey)
      )
    case 'workspace://surface/node-catalog/viewport/screenshot':
      return asResourceResult(uri, await captureWorkspaceScreenshot(context, 'node-catalog'))
    default:
      throw new Error(`Unknown resource: ${uri}`)
  }
}

function buildPrompt(name) {
  switch (name) {
    case 'canvas-layout-review':
      return {
        description: 'Inspect the current freeform canvas before mutating it.',
        messages: [
          {
            role: 'user',
            content: {
              type: 'text',
              text:
                'Start with workspace://manifest, then inspect workspace://surface/canvas/state, workspace://surface/canvas/selection, and workspace://surface/canvas/primitives. Capture workspace://surface/canvas/viewport/screenshot when visual confirmation matters. Summarize the current board briefly before calling any write tools. Prefer create_artboard, create_primitive_item, update_item, select_items, and export_board over shell edits when the task is scene-graph related.',
            },
          },
        ],
      }
    case 'build-color-audit-palette':
      return {
        description: 'Inspect and iterate on the Color Audit workspace.',
        messages: [
          {
            role: 'user',
            content: {
              type: 'text',
              text:
                'Read workspace://surface/color-audit/manifest, workspace://surface/color-audit/state, and workspace://surface/color-audit/export-preview. Capture workspace://surface/color-audit/viewport/screenshot when visual confirmation matters. Summarize the current palette inputs, functional aliases, semantic roles, contrast coverage, and export readiness before proposing changes. When you need to mutate the graph, prefer generate_template for seeded starters and create_color_node/update_color_node/create_color_edge/update_color_edge/delete_color_edge for targeted graph edits.',
            },
          },
        ],
      }
    case 'audit-color-contrast':
      return {
        description: 'Review Color Audit contrast status and missing pair coverage.',
        messages: [
          {
            role: 'user',
            content: {
              type: 'text',
              text:
                'Inspect workspace://surface/color-audit/state and focus on workflow readiness, mapped semantic roles, and any contrast pairs. Capture workspace://surface/color-audit/viewport/screenshot when you need a rendered comparison. Call out missing or weak text/surface relationships and compare the export preview against the current role graph before suggesting follow-up work.',
            },
          },
        ],
      }
    case 'review-scale-system':
      return {
        description: 'Review the generated System Canvas graph, section coverage, and responsive preview quality.',
        messages: [
          {
            role: 'user',
            content: {
              type: 'text',
              text:
                'Read workspace://surface/system-canvas/manifest and workspace://surface/system-canvas/state. Capture workspace://surface/system-canvas/viewport/screenshot when visual confirmation matters. Summarize the active scale config, current view mode, section coverage, and missing preview requirements. Use update_system_scale_config to adjust the engine, set_system_canvas_view to change subviews, generate_scale_graph to rebuild previews, apply_scale_vars when the theme vars should be pushed back into the active theme, and create_system_node/update_system_node/create_system_edge/update_system_edge/delete_system_edge for explicit graph authoring.',
            },
          },
        ],
      }
    case 'review-node-system':
      return {
        description: 'Review the visual node system across Canvas Workspace, Color Audit, System Canvas, and Node Catalog.',
        messages: [
          {
            role: 'user',
            content: {
              type: 'text',
              text:
                'Start with workspace://manifest, then read workspace://surface/node-catalog/state and workspace://surface/node-catalog/sections. Capture workspace://surface/node-catalog/viewport/screenshot when visual confirmation matters. Review node-card titles, subtitles, pills, swatches, ports, overflow, selected state, highlighted state, and dimmed state across the catalog surfaces before suggesting UI changes.',
            },
          },
        ],
      }
    default:
      throw new Error(`Unknown prompt: ${name}`)
  }
}

async function runCreateArtboard(args) {
  const state = await readCanvasAgentState(context)
  return applyOperation(
    'create_artboard',
    createCreateItemOperation(createArtboardItem(state, args), args.select !== false)
  )
}

async function runCreatePrimitiveItem(args) {
  const primitive = await getPrimitiveById(normalizeString(args.primitiveId))
  if (!primitive) return asToolError(`Primitive not found: ${args.primitiveId || ''}`)

  try {
    const state = await readCanvasAgentState(context)
    const item = createPrimitiveCanvasItem(state, primitive, args)
    const variant = primitive.variants[item.variantIndex]
    return applyOperation(
      'create_primitive_item',
      createCreateItemOperation(item, args.select !== false),
      {
        primitiveId: primitive.primitiveId,
        entryId: primitive.entryId,
        variantName: variant?.name,
      }
    )
  } catch (error) {
    return asToolError(error instanceof Error ? error.message : 'Failed to create primitive item.')
  }
}

async function runCreateItem(args) {
  if (!args.item || typeof args.item !== 'object') {
    return asToolError('item is required.')
  }
  return applyOperation('create_item', createCreateItemOperation(args.item, args.select !== false))
}

async function runUpdateItem(args) {
  const id = normalizeString(args.id)
  if (!id) return asToolError('id is required.')
  if (!args.updates || typeof args.updates !== 'object') {
    return asToolError('updates is required.')
  }
  return applyOperation('update_item', createUpdateItemOperation(id, args.updates))
}

async function runDeleteItems(args) {
  const ids = normalizeIdList(args.ids)
  if (ids.length === 0) return asToolError('ids is required.')
  return applyOperation('delete_items', createDeleteItemsOperation(ids))
}

async function runSelectItems(args) {
  const ids = normalizeIdList(args.ids)
  return applyOperation('select_items', createSelectItemsOperation(ids))
}

async function runClearCanvas() {
  return applyOperation('clear_canvas', createClearCanvasOperation())
}

async function runExportBoard(args) {
  const artboardId = normalizeString(args.artboardId)
  if (!artboardId) return asToolError('artboardId is required.')
  const format = normalizeString(args.format) || DEFAULT_EXPORT_FORMAT
  if (!EXPORT_FORMATS.has(format)) {
    return asToolError(`Unsupported export format: ${format}`)
  }

  try {
    const [state, primitives] = await Promise.all([
      readCanvasAgentState(context),
      readCanvasAgentPrimitives(context),
    ])
    return asToolResult(
      exportCanvasBoard({
        artboardId,
        format,
        componentName: args.componentName,
        state,
        primitives,
      })
    )
  } catch (error) {
    return asToolError(error instanceof Error ? error.message : 'Failed to export board.')
  }
}

async function applyColorAuditOperation(toolName, operation, meta = {}) {
  const result = await enqueueAgentNativeWorkspaceOperation(
    context,
    'color-audit',
    context.colorAuditWorkspaceKey,
    operation,
    {
      source: 'canvas-agent-mcp',
    }
  )
  if (!result?.ok) return asToolError(result?.error || `Failed to apply ${toolName}.`)
  return asToolResult({
    ...result,
    ...meta,
  })
}

async function applySystemCanvasOperation(toolName, operation, meta = {}) {
  const result = await enqueueAgentNativeWorkspaceOperation(
    context,
    'system-canvas',
    context.systemCanvasWorkspaceKey,
    operation,
    {
      source: 'canvas-agent-mcp',
      ...meta,
    }
  )

  return asToolResult({
    ...result,
    tool: toolName,
    workspaceId: 'system-canvas',
  })
}

async function runGenerateTemplate(args) {
  const templateKitId = normalizeString(args.templateKitId)
  if (!['starter', 'shadcn', 'radix'].includes(templateKitId)) {
    return asToolError('templateKitId must be one of: starter, shadcn, radix.')
  }
  return applyColorAuditOperation('generate_template', {
    type: 'generate-template',
    templateKitId,
    brandColor: normalizeString(args.brandColor) || undefined,
    accentColor: normalizeString(args.accentColor) || undefined,
  })
}

