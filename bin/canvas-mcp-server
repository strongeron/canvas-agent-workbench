  {
    name: 'clear_canvas',
    description: 'Remove all items and groups from the current canvas.',
    inputSchema: {
      type: 'object',
      properties: {},
      additionalProperties: false,
    },
  },
  {
    name: 'export_board',
    description:
      'Export a primitive-only artboard as React code. Current export preserves canvas positioning rather than reconstructing semantic layout.',
    inputSchema: {
      type: 'object',
      properties: {
        artboardId: { type: 'string' },
        format: { type: 'string', enum: ['react-tailwind', 'react-css-vars'] },
        componentName: { type: 'string' },
      },
      required: ['artboardId'],
      additionalProperties: false,
    },
