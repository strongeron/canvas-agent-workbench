      required: ['item'],
      additionalProperties: false,
    },
  },
  {
    name: 'update_item',
    description: 'Update an existing canvas item by id.',
    inputSchema: {
      type: 'object',
      properties: {
        id: { type: 'string' },
        updates: { type: 'object' },
      },
      required: ['id', 'updates'],
      additionalProperties: false,
    },
  },
  {
    name: 'delete_items',
    description: 'Delete one or more canvas items by id.',
    inputSchema: {
      type: 'object',
      properties: {
        ids: {
          type: 'array',
          items: { type: 'string' },
          minItems: 1,
        },
      },
      required: ['ids'],
      additionalProperties: false,
    },
  },
  {
    name: 'select_items',
    description: 'Replace the current selection with the provided item ids.',
    inputSchema: {
      type: 'object',
      properties: {
        ids: {
          type: 'array',
          items: { type: 'string' },
