async function applyOperation(toolName, operation, meta = {}) {
  const result = await enqueueCanvasAgentOperation(context, toolName, operation, {
    source: 'canvas-agent-mcp',
  })
  if (!result.ok) return asToolError(result.error || `Failed to apply ${toolName}.`)
  return asToolResult({
    ...result,
    ...meta,
  })
}

async function getPrimitiveById(primitiveId) {
  if (!primitiveId) return null
  const primitives = await readCanvasAgentPrimitives(context)
  return primitives.find((entry) => entry.primitiveId === primitiveId || entry.entryId === primitiveId) || null
}

function cycleVariantIndex(currentIndex, variantCount, direction) {
  if (!Number.isInteger(currentIndex) || !Number.isInteger(variantCount) || variantCount <= 0) {
    return 0
  }
  if (variantCount === 1) return 0
  if (direction === 'previous') {
    return Math.max(0, currentIndex - 1)
  }
  return Math.min(variantCount - 1, currentIndex + 1)
}

function updateMermaidNodeLabelLocal(source, nodeId, nextLabel) {
  const trimmedLabel = typeof nextLabel === 'string' ? nextLabel.trim() : ''
  if (!trimmedLabel) return source

  const pattern = new RegExp(
    `\\b(${escapeRegExpLocal(nodeId)})\\s*([[({])([^[\\]{}()]+?)([\\])}])`,
    'g'
  )

  return String(source || '').replace(pattern, (_, id, open, _current, close) => {
    return `${id}${open}${trimmedLabel}${close}`
  })
}

function escapeRegExpLocal(value) {
  return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
}

function flattenCanvasSummaryItems(summary) {
  const map = new Map()
  for (const artboard of Array.isArray(summary?.artboards) ? summary.artboards : []) {
    map.set(artboard.id, artboard)
    for (const item of Array.isArray(artboard.children) ? artboard.children : []) {
      map.set(item.id, item)
    }
  }
  for (const item of Array.isArray(summary?.looseItems) ? summary.looseItems : []) {
    map.set(item.id, item)
  }
  return map
}

function normalizeComponentNameForImport(value) {
  const words = normalizeString(value).match(/[A-Za-z0-9]+/g)
  if (!words || words.length === 0) return 'GeneratedComponent'
  const name = words.map((word) => word.charAt(0).toUpperCase() + word.slice(1)).join('')
  return /^[A-Za-z]/.test(name) ? name : `Component${name}`
}

function asToolResult(payload) {
  return {
    content: [
      {
        type: 'text',
        text: JSON.stringify(payload, null, 2),
      },
    ],
    structuredContent: payload,
  }
}

function asToolError(message) {
  return {
    isError: true,
    content: [
      {
        type: 'text',
        text: String(message || 'Canvas MCP tool failed.'),
      },
    ],
  }
}

function asResourceResult(uri, payload) {
  return {
    contents: [
      {
        uri,
        mimeType: 'application/json',
        text: JSON.stringify(payload, null, 2),
      },
    ],
  }
}

function sendResponse(id, result) {
  sendMessage({
    jsonrpc: '2.0',
    id,
    result,
  })
}

function sendError(id, code, message, data = undefined) {
  sendMessage({
    jsonrpc: '2.0',
    id,
    error: {
      code,
      message,
      data,
    },
  })
}

function sendMessage(payload) {
  const body = JSON.stringify(payload)
  process.stdout.write(`Content-Length: ${Buffer.byteLength(body, 'utf8')}\r\n\r\n${body}`)
}
