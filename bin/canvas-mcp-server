#!/usr/bin/env node

import {
  buildCanvasContextSummary,
  enqueueCanvasAgentOperation,
  getCanvasAgentContextFromEnv,
  readCanvasAgentPrimitives,
  readCanvasAgentSelection,
  readCanvasAgentState,
} from './canvas-agent-runtime.mjs'

const SERVER_INFO = {
  name: 'canvas-agent-mcp',
  version: '0.2.0',
}

const FALLBACK_PROTOCOL_VERSION = '2025-03-26'
const DEFAULT_ARTBOARD_LAYOUT = {
  display: 'flex',
  direction: 'column',
  align: 'stretch',
  justify: 'start',
  gap: 24,
  padding: 32,
}
const DEFAULT_ARTBOARD_SIZE = { width: 1440, height: 900 }
const DEFAULT_ARTBOARD_POSITION = { x: 120, y: 120 }
const DEFAULT_EXPORT_FORMAT = 'react-tailwind'
const EXPORT_FORMATS = new Set(['react-tailwind', 'react-css-vars'])

const TOOL_DEFINITIONS = [
  {
    name: 'get_canvas_context',
    description:
      'Return an LLM-friendly summary of the current canvas, grouped by artboards and loose items.',
    inputSchema: {
      type: 'object',
      properties: {},
      additionalProperties: false,
    },
  },
  {
    name: 'get_canvas_state',
    description: 'Return the raw current canvas state snapshot.',
    inputSchema: {
      type: 'object',
      properties: {},
      additionalProperties: false,
    },
  },
  {
    name: 'get_canvas_selection',
    description: 'Return the current selection and summaries for selected items.',
    inputSchema: {
      type: 'object',
      properties: {},
      additionalProperties: false,
    },
  },
  {
    name: 'list_primitives',
    description:
      'List registered HTML/CSS-native primitives available to the current canvas project.',
    inputSchema: {
      type: 'object',
      properties: {
        family: { type: 'string', description: 'Optional primitive family filter.' },
        level: {
          type: 'string',
          enum: ['primitive', 'composite'],
          description: 'Optional primitive level filter.',
        },
        exportable: {
          type: 'boolean',
          description: 'Optional filter for exportable primitives.',
        },
      },
      additionalProperties: false,
    },
  },
  {
    name: 'get_primitive',
    description: 'Return deep metadata for a primitive by primitiveId or entryId.',
    inputSchema: {
      type: 'object',
      properties: {
        primitiveId: { type: 'string' },
      },
      required: ['primitiveId'],
      additionalProperties: false,
    },
  },
  {
    name: 'create_artboard',
    description: 'Create an artboard with sensible defaults and optional layout overrides.',
    inputSchema: {
      type: 'object',
      properties: {
        name: { type: 'string' },
        position: positionSchema(),
        size: sizeSchema(),
        background: { type: 'string' },
        themeId: { type: 'string' },
        layout: {
          type: 'object',
          properties: {
            display: { type: 'string', enum: ['flex', 'grid'] },
            direction: { type: 'string', enum: ['row', 'column'] },
            align: { type: 'string', enum: ['start', 'center', 'end', 'stretch'] },
            justify: { type: 'string', enum: ['start', 'center', 'end', 'between'] },
            gap: { type: 'number' },
            columns: { type: 'number' },
            padding: { type: 'number' },
          },
          additionalProperties: false,
        },
        select: { type: 'boolean' },
      },
      additionalProperties: false,
    },
  },
  {
    name: 'create_primitive_item',
    description:
      'Create a component item from a registered primitive using primitiveId and variant metadata.',
    inputSchema: {
      type: 'object',
      properties: {
        primitiveId: { type: 'string' },
        variantName: { type: 'string' },
        variantIndex: { type: 'number' },
        position: positionSchema(),
        size: sizeSchema(),
        parentId: { type: 'string' },
        props: { type: 'object' },
        select: { type: 'boolean' },
      },
      required: ['primitiveId'],
      additionalProperties: false,
    },
  },
  {
    name: 'create_item',
    description: 'Create a canvas item and optionally select it.',
    inputSchema: {
      type: 'object',
      properties: {
