async function runUpdateMermaidLabel(args) {
  const itemId = normalizeString(args.itemId)
  const nodeId = normalizeString(args.nodeId)
  const label = typeof args.label === 'string' ? args.label : ''
  if (!itemId) return asToolError('itemId is required.')
  if (!nodeId) return asToolError('nodeId is required.')
  if (!label.trim()) return asToolError('label is required.')

  const state = await readCanvasAgentState(context)
  const item = Array.isArray(state?.items) ? state.items.find((entry) => entry?.id === itemId) : null
  if (!item || item.type !== 'mermaid') return asToolError(`Mermaid item not found: ${itemId}`)

  const nextSource = updateMermaidNodeLabelLocal(item.source, nodeId, label)
  if (nextSource === item.source) {
    return asToolResult({
      ok: true,
      itemId,
      nodeId,
      source: item.source,
      changed: false,
    })
  }

  return applyOperation(
    'update_mermaid_label',
    createUpdateItemOperation(itemId, { source: nextSource }),
    {
      itemId,
      nodeId,
      source: nextSource,
      changed: true,
    }
  )
}

