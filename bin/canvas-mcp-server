async function runUpdateMarkdownBlock(args) {
  const itemId = normalizeString(args.itemId)
  const action = normalizeString(args.action)
  if (!itemId) return asToolError('itemId is required.')
  if (!action || !['update', 'reorder'].includes(action)) {
    return asToolError('action must be update or reorder.')
  }

  const state = await readCanvasAgentState(context)
  const item = Array.isArray(state?.items) ? state.items.find((entry) => entry?.id === itemId) : null
  if (!item || item.type !== 'markdown') return asToolError(`Markdown item not found: ${itemId}`)

  const request =
    action === 'update'
      ? {
          action,
          blockIndex: Number.isInteger(args.blockIndex) ? Number(args.blockIndex) : -1,
          newText: typeof args.newText === 'string' ? args.newText : '',
        }
      : {
          action,
          fromIndex: Number.isInteger(args.fromIndex) ? Number(args.fromIndex) : -1,
          toIndex: Number.isInteger(args.toIndex) ? Number(args.toIndex) : -1,
        }

  if (action === 'update' && request.blockIndex < 0) {
    return asToolError('blockIndex is required for update.')
  }
  if (action === 'reorder' && (request.fromIndex < 0 || request.toIndex < 0)) {
    return asToolError('fromIndex and toIndex are required for reorder.')
  }

  const writeResult = await updateCanvasMarkdownDocument(context, {
    filePath: normalizeString(item.sourcePath) || undefined,
    markdownSource: item.source,
    mtimeMs: typeof item.sourceFileMtime === 'number' ? item.sourceFileMtime : undefined,
    ...request,
  })

  const updates = {
    source: writeResult.source,
    ...(typeof writeResult.mtimeMs === 'number' ? { sourceFileMtime: writeResult.mtimeMs } : {}),
  }

  return applyOperation(
    'update_markdown_block',
    createUpdateItemOperation(itemId, updates),
    {
      itemId,
      action,
      source: writeResult.source,
      ...(typeof writeResult.mtimeMs === 'number' ? { mtimeMs: writeResult.mtimeMs } : {}),
    }
  )
}

async function runCycleComponentVariant(args) {
  const itemId = normalizeString(args.itemId)
  const direction = normalizeString(args.direction)
  if (!itemId) return asToolError('itemId is required.')
  if (!direction || !['previous', 'next'].includes(direction)) {
    return asToolError('direction must be previous or next.')
  }

  const state = await readCanvasAgentState(context)
  const item = Array.isArray(state?.items) ? state.items.find((entry) => entry?.id === itemId) : null
  if (!item || item.type !== 'component') return asToolError(`Component item not found: ${itemId}`)

  const primitives = await readCanvasAgentPrimitives(context)
  const primitive = Array.isArray(primitives)
    ? primitives.find((entry) => entry?.entryId === item.componentId || entry?.primitiveId === item.componentId)
    : null
  const variantCount = Array.isArray(primitive?.variants) ? primitive.variants.length : 0
  if (variantCount <= 0) {
    return asToolError(`Primitive variants not found for component: ${item.componentId}`)
  }

  const nextVariantIndex = cycleVariantIndex(
    Number.isInteger(item.variantIndex) ? item.variantIndex : 0,
    variantCount,
    direction
  )

  if (nextVariantIndex === item.variantIndex) {
    return asToolResult({
      ok: true,
      itemId,
      variantIndex: item.variantIndex,
      changed: false,
    })
  }

  return applyOperation(
    'cycle_component_variant',
    createUpdateItemOperation(itemId, {
      variantIndex: nextVariantIndex,
      customProps: undefined,
    }),
    {
      itemId,
      variantIndex: nextVariantIndex,
      changed: true,
    }
  )
}

async function runUpdateArtboardLayout(args) {
  const itemId = normalizeString(args.itemId)
  if (!itemId) return asToolError('itemId is required.')
  if (!args.layout || typeof args.layout !== 'object') {
    return asToolError('layout is required.')
  }

  const state = await readCanvasAgentState(context)
  const item = Array.isArray(state?.items) ? state.items.find((entry) => entry?.id === itemId) : null
  if (!item || item.type !== 'artboard') return asToolError(`Artboard not found: ${itemId}`)

  const layout = {
    ...(item.layout && typeof item.layout === 'object' ? item.layout : {}),
    ...args.layout,
  }

  return applyOperation(
    'update_artboard_layout',
    createUpdateItemOperation(itemId, { layout }),
    {
      itemId,
      layout,
    }
  )
}

