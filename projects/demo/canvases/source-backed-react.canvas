        "sourceReact": "export default function PreviewCard() {\n  return (\n    <main style={{ minHeight: '100vh', margin: 0, display: 'grid', placeItems: 'center', background: '#f8fafc', fontFamily: 'Inter, system-ui, sans-serif' }}>\n      <article style={{ width: 'min(420px, calc(100vw - 48px))', padding: 24, border: '1px solid #cbd5e1', borderRadius: 16, background: '#ffffff', boxShadow: '0 20px 40px rgb(15 23 42 / 0.08)' }}>\n        <h1 style={{ margin: '0 0 12px', fontSize: 28, lineHeight: 1.1 }}>Hello</h1>\n        <p style={{ margin: '0 0 16px', color: '#475569', lineHeight: 1.5 }}>React bridge verification target</p>\n        <button className=\"cta\">Click</button>\n      </article>\n    </main>\n  )\n}\n",
