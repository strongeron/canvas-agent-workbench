      {
        "id": "canvas-item-sbwrapper-rolecanvas",
        "type": "html",
        "title": "RoleCanvas",
        "sourceMode": "react",
        "sourceReact": "/**\n * RoleCanvas preview harness — self-contained for the gallery-poc canvas.\n * Inlines the RoleCanvas wrapper plus a role-aware LessonCard fixture so\n * the same component renders per user role.\n */\nimport React, { type ComponentType, type ReactNode } from 'react';\n\ninterface RoleCanvasProps<P> {\n  component: ComponentType<P & { role?: string }>;\n  roles: string[];\n  args?: P;\n  roleArgs?: Record<string, Partial<P>>;\n  renderRow?: (role: string, content: ReactNode) => ReactNode;\n}\n\nfunction RoleCanvas<P>({ component: Component, roles, args, roleArgs, renderRow }: RoleCanvasProps<P>) {\n  return (\n    <div className=\"role-canvas\" style={{ display: 'grid', gap: '0.8rem' }}>\n      {roles.map((role) => {\n        const mergedProps = { ...(args ?? {}), ...(roleArgs?.[role] ?? {}), role } as P & { role: string };\n        const content = <Component {...mergedProps} />;\n        if (renderRow) return <div key={role}>{renderRow(role, content)}</div>;\n        return (\n          <div\n            key={role}\n            className=\"role-row\"\n            style={{\n              display: 'grid',\n              gridTemplateColumns: '110px 1fr',\n              gap: '1rem',\n              alignItems: 'center',\n              padding: '0.7rem',\n              background: '#f9fafb',\n              borderRadius: 6,\n            }}\n          >\n            <span\n              className=\"role-label\"\n              style={{\n                fontSize: '0.72rem',\n                textTransform: 'uppercase',\n                letterSpacing: '0.06em',\n                fontWeight: 700,\n                color: '#666',\n              }}\n            >\n              {role}\n            </span>\n            <div\n              className=\"role-content\"\n              style={{ background: 'white', padding: '0.5rem 0.8rem', border: '1px solid #e2e0db', borderRadius: 4 }}\n            >\n              {content}\n            </div>\n          </div>\n        );\n      })}\n    </div>\n  );\n}\n\n// --- Fixtures ----------------------------------------------------------------\n\ninterface Lesson {\n  title: string;\n  status: string;\n}\n\ninterface LessonCardProps {\n  lesson: Lesson;\n  role?: string;\n}\n\nfunction LessonCard({ lesson, role }: LessonCardProps) {\n  const canEdit = role === 'teacher' || role === 'admin';\n  const canDelete = role === 'admin';\n  return (\n    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '1rem' }}>\n      <div>\n        <strong style={{ fontSize: '0.9rem' }}>{lesson.title}</strong>\n        <div style={{ fontSize: '0.75rem', color: '#888' }}>{lesson.status}</div>\n      </div>\n      <div style={{ display: 'flex', gap: '0.4rem' }}>\n        <button style={btn('#2b5cd9')}>Open</button>\n        {canEdit && <button style={btn('#a16207')}>Edit</button>}\n        {canDelete && <button style={btn('#b91c1c')}>Delete</button>}\n      </div>\n    </div>\n  );\n}\n\nfunction btn(color: string): React.CSSProperties {\n  return {\n    background: color,\n    color: 'white',\n    border: 'none',\n    borderRadius: 4,\n    padding: '0.3rem 0.7rem',\n    fontSize: '0.75rem',\n    cursor: 'pointer',\n  };\n}\n\nexport default function Preview() {\n  return (\n    <div style={{ padding: 24, background: '#ffffff', fontFamily: 'system-ui, sans-serif' }}>\n      <RoleCanvas\n        component={LessonCard}\n        roles={['teacher', 'student', 'admin']}\n        args={{ lesson: { title: 'Intro to OKLCH', status: 'Published · 12 students' } }}\n      />\n    </div>\n  );\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 1824,
          "y": 276
        },
        "size": {
