      {
        "id": "canvas-item-sbwrapper-projectinventory",
        "type": "html",
        "title": "ProjectInventory",
        "sourceMode": "react",
        "sourceReact": "// Self-contained preview harness for ProjectInventory wrapper.\n// import.meta.glob (Vite-only) replaced with a fixture report prop; Icon set inlined.\nimport React, { type CSSProperties, type ReactElement, type ReactNode } from 'react';\n\n// ── inlined minimal Icon set ──\ntype WrapperIcon = (p: { size?: number; style?: CSSProperties }) => ReactElement;\nconst svg = (path: ReactElement): WrapperIcon =>\n  function I({ size = 15, style }: { size?: number; style?: CSSProperties }) {\n    return (\n      <svg width={size} height={size} viewBox=\"0 0 24 24\" fill=\"none\"\n        stroke=\"currentColor\" strokeWidth={1.6} strokeLinecap=\"round\" strokeLinejoin=\"round\"\n        style={{ flexShrink: 0, verticalAlign: 'text-bottom', ...style }} aria-hidden>\n        {path}\n      </svg>\n    );\n  };\nconst Icon = {\n  palette: svg(<>\n    <circle cx=\"13.5\" cy=\"6.5\" r=\"1.2\" fill=\"currentColor\" stroke=\"none\" />\n    <circle cx=\"17.5\" cy=\"10.5\" r=\"1.2\" fill=\"currentColor\" stroke=\"none\" />\n    <circle cx=\"8.5\" cy=\"7.5\" r=\"1.2\" fill=\"currentColor\" stroke=\"none\" />\n    <circle cx=\"6.5\" cy=\"12.5\" r=\"1.2\" fill=\"currentColor\" stroke=\"none\" />\n    <path d=\"M12 2a10 10 0 1 0 0 20c1.1 0 2-.9 2-2 0-.5-.2-1-.6-1.4-.4-.4-.6-.9-.6-1.4 0-1.1.9-2 2-2h2.4A4.8 4.8 0 0 0 22 10.4 10 10 0 0 0 12 2Z\" />\n  </>),\n  warning: svg(<>\n    <path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\" />\n    <path d=\"M12 9v4\" /><path d=\"M12 17h.01\" />\n  </>),\n  tokens: svg(<>\n    <circle cx=\"12\" cy=\"12\" r=\"9\" /><circle cx=\"12\" cy=\"12\" r=\"5\" /><circle cx=\"12\" cy=\"12\" r=\"1.4\" fill=\"currentColor\" stroke=\"none\" />\n  </>),\n  alert: svg(<>\n    <path d=\"M12 3a6 6 0 0 0-6 6c0 5-2 6-2 6h16s-2-1-2-6a6 6 0 0 0-6-6Z\" />\n    <path d=\"M10.3 21a2 2 0 0 0 3.4 0\" />\n  </>),\n  star: svg(<path d=\"M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5Z\" />),\n  check: svg(<path d=\"M20 6 9 17l-5-5\" />),\n  dot: svg(<circle cx=\"12\" cy=\"12\" r=\"5\" fill=\"currentColor\" stroke=\"none\" />),\n  box: svg(<><path d=\"M3 7l9-4 9 4-9 4-9-4Z\" /><path d=\"M3 7v10l9 4 9-4V7\" /><path d=\"M12 11v10\" /></>),\n};\n\ninterface ProjectInventoryReport {\n  generatedAt?: string;\n  ranBy?: string;\n  libraries: {\n    react: boolean; vite: boolean; tailwindV4: boolean; tailwindV3: boolean;\n    shadcn: boolean; radix: boolean; baseui: boolean; r3f: boolean;\n  };\n  designSystem: {\n    dominant: 'tailwind-v4' | 'shadcn' | 'dtcg' | 'css-vars' | 'none';\n    mixed: boolean;\n    mixedReason?: string | null;\n    tokenCounts: { 'tailwind-v4': number; shadcn: number; dtcg: number; 'css-vars': number };\n  };\n  components: {\n    totalFiles: number; realCount: number; deadCount: number;\n    real: Array<{ file: string; importers: number }>;\n    dead: Array<{ file: string; importers: number }>;\n  };\n  tokens: { totalDeclared: number; usedCount: number; orphanCount: number; orphan: string[] };\n  orphanStories: { count: number; items: Array<{ story: string; missing_import: string }> };\n}\n\nfunction Card({ children, color = '#fafafa' }: { children: ReactNode; color?: string }): ReactElement {\n  return (\n    <div style={{ background: color, border: '1px solid #e2e0db', borderRadius: 8, padding: '1rem 1.2rem' }}>\n      {children}\n    </div>\n  );\n}\n\nfunction Pill({ on, label }: { on: boolean; label: string }): ReactElement {\n  return (\n    <span style={{\n      display: 'inline-flex', alignItems: 'center', gap: '0.3rem',\n      padding: '0.15rem 0.55rem', borderRadius: 4,\n      background: on ? '#dcfce7' : '#f3f4f6',\n      color:      on ? '#15803d' : '#9ca3af',\n      fontSize: '0.78rem', fontWeight: 600,\n    }}>\n      {on ? <Icon.check size={12} /> : <Icon.dot size={8} />} {label}\n    </span>\n  );\n}\n\nfunction SourceBar({ counts }: { counts: ProjectInventoryReport['designSystem']['tokenCounts'] }): ReactElement {\n  const total = Math.max(1, counts['tailwind-v4'] + counts['shadcn'] + counts['dtcg'] + counts['css-vars']);\n  const labels: Array<keyof typeof counts> = ['tailwind-v4', 'shadcn', 'dtcg', 'css-vars'];\n  const colorMap: Record<string, string> = { 'tailwind-v4': '#06b6d4', shadcn: '#6366f1', dtcg: '#f59e0b', 'css-vars': '#9ca3af' };\n  return (\n    <div>\n      <div style={{ display: 'flex', height: 28, borderRadius: 4, overflow: 'hidden', border: '1px solid #e2e0db' }}>\n        {labels.map((k) => {\n          const w = (counts[k] / total) * 100;\n          if (w === 0) return null;\n          return <div key={k} style={{ width: `${w}%`, background: colorMap[k], minWidth: 1 }} title={`${k}: ${counts[k]}`} />;\n        })}\n      </div>\n      <div style={{ display: 'flex', gap: '0.6rem', flexWrap: 'wrap', marginTop: '0.4rem', fontSize: '0.78rem' }}>\n        {labels.map((k) => (\n          <span key={k} style={{ display: 'inline-flex', alignItems: 'center', gap: '0.3rem' }}>\n            <span style={{ width: 10, height: 10, background: colorMap[k], borderRadius: 2 }} />\n            {k}: {counts[k]}\n          </span>\n        ))}\n      </div>\n    </div>\n  );\n}\n\nfunction ProjectInventory({ report }: { report: ProjectInventoryReport }): ReactElement {\n  const slopRate = report.components.totalFiles > 0\n    ? Math.round((report.components.deadCount / report.components.totalFiles) * 100)\n    : 0;\n\n  return (\n    <div style={{ padding: '1.5rem', maxWidth: 1100, margin: '0 auto' }}>\n      <header style={{ marginBottom: '1.5rem' }}>\n        <h1 style={{ margin: 0, fontSize: '1.4rem' }}>Project inventory · ground truth</h1>\n        <p style={{ margin: '0.3rem 0 0', color: '#666', fontSize: '0.86rem' }}>\n          {report.generatedAt && <>Generated {report.generatedAt}</>}\n          {report.ranBy && <> · by {report.ranBy}</>}\n        </p>\n      </header>\n\n      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))', gap: '1rem', marginBottom: '1.5rem' }}>\n        <Card>\n          <h3 style={{ margin: '0 0 0.6rem', fontSize: '0.95rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}><Icon.box /> Stack</h3>\n          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.4rem' }}>\n            <Pill on={report.libraries.react}      label=\"React\" />\n            <Pill on={report.libraries.vite}       label=\"Vite\" />\n            <Pill on={report.libraries.tailwindV4} label=\"Tailwind v4\" />\n            <Pill on={report.libraries.tailwindV3} label=\"Tailwind v3\" />\n            <Pill on={report.libraries.shadcn}     label=\"shadcn\" />\n            <Pill on={report.libraries.radix}      label=\"Radix UI\" />\n            <Pill on={report.libraries.baseui}     label=\"Base UI\" />\n            <Pill on={report.libraries.r3f}        label=\"R3F\" />\n          </div>\n        </Card>\n\n        <Card color={report.designSystem.mixed ? '#fef3c7' : '#dbeafe'}>\n          <h3 style={{ margin: '0 0 0.4rem', fontSize: '0.95rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}><Icon.palette /> Design system</h3>\n          <div style={{ fontSize: '1.05rem', fontWeight: 700, marginBottom: '0.3rem' }}>\n            {report.designSystem.dominant === 'none' ? '(none detected)' : report.designSystem.dominant}\n          </div>\n          {report.designSystem.mixed && (\n            <p style={{ margin: '0 0 0.5rem', fontSize: '0.8rem', color: '#92400e', display: 'flex', alignItems: 'center', gap: '0.3rem' }}>\n              <Icon.warning size={13} /> Mixed: {report.designSystem.mixedReason}\n            </p>\n          )}\n          <SourceBar counts={report.designSystem.tokenCounts} />\n        </Card>\n\n        <Card color={slopRate > 20 ? '#fee2e2' : '#dcfce7'}>\n          <h3 style={{ margin: '0 0 0.4rem', fontSize: '0.95rem' }}>Components</h3>\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '0.6rem', textAlign: 'center' }}>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700 }}>{report.components.realCount}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Real</div>\n            </div>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700, color: slopRate > 20 ? '#b91c1c' : '#a16207' }}>{report.components.deadCount}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Dead</div>\n            </div>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700, color: '#666' }}>{report.components.totalFiles}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Total</div>\n            </div>\n          </div>\n          <p style={{ margin: '0.6rem 0 0', fontSize: '0.78rem', color: '#666' }}>\n            Slop rate: <strong>{slopRate}%</strong>\n          </p>\n        </Card>\n\n        <Card>\n          <h3 style={{ margin: '0 0 0.4rem', fontSize: '0.95rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}><Icon.tokens /> Tokens</h3>\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '0.6rem', textAlign: 'center' }}>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700 }}>{report.tokens.usedCount}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Used</div>\n            </div>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700, color: '#a16207' }}>{report.tokens.orphanCount}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Orphan</div>\n            </div>\n            <div>\n              <div style={{ fontSize: '1.2rem', fontWeight: 700, color: '#666' }}>{report.tokens.totalDeclared}</div>\n              <div style={{ fontSize: '0.7rem', color: '#666', textTransform: 'uppercase', letterSpacing: '0.04em' }}>Declared</div>\n            </div>\n          </div>\n        </Card>\n      </div>\n\n      {report.orphanStories.count > 0 && (\n        <section style={{ marginBottom: '1.5rem' }}>\n          <h2 style={{ fontSize: '1.05rem', margin: '0 0 0.6rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}>\n            <Icon.alert /> Orphan stories ({report.orphanStories.count})\n            <span style={{ fontWeight: 400, fontSize: '0.82rem', color: '#666' }}> · stories importing components that no longer exist</span>\n          </h2>\n          {report.orphanStories.items.slice(0, 10).map((o, i) => (\n            <div key={i} style={{ background: '#fef2f2', border: '1px solid #fca5a5', borderRadius: 5, padding: '0.5rem 0.8rem', marginBottom: '0.4rem', fontSize: '0.82rem' }}>\n              <code style={{ fontSize: '0.78rem' }}>{o.story}</code>\n              <div style={{ color: '#7f1d1d', fontSize: '0.74rem' }}>missing: <code>{o.missing_import}</code></div>\n            </div>\n          ))}\n        </section>\n      )}\n\n      {report.components.dead.length > 0 && (\n        <section style={{ marginBottom: '1.5rem' }}>\n          <h2 style={{ fontSize: '1.05rem', margin: '0 0 0.6rem' }}>\n            Dead components — top 20\n            <span style={{ fontWeight: 400, fontSize: '0.82rem', color: '#666' }}> · defined but never imported outside their own file</span>\n          </h2>\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(360px, 1fr))', gap: '0.5rem' }}>\n            {report.components.dead.slice(0, 20).map((c, i) => (\n              <code key={i} style={{ fontSize: '0.78rem', background: '#fef3c7', padding: '0.3rem 0.6rem', borderRadius: 4, color: '#7c2d12', wordBreak: 'break-all' }}>\n                {c.file}\n              </code>\n            ))}\n          </div>\n        </section>\n      )}\n\n      <section style={{ marginBottom: '1.5rem' }}>\n        <h2 style={{ fontSize: '1.05rem', margin: '0 0 0.6rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}>\n          <Icon.star /> Top real components\n          <span style={{ fontWeight: 400, fontSize: '0.82rem', color: '#666' }}> · most-imported (priority for stories)</span>\n        </h2>\n        <div style={{ display: 'grid', gap: '0.4rem' }}>\n          {report.components.real.slice(0, 10).map((c, i) => (\n            <div key={i} style={{ display: 'grid', gridTemplateColumns: '1fr 100px', gap: '0.6rem', alignItems: 'center', background: '#fafafa', padding: '0.5rem 0.8rem', borderRadius: 5, fontSize: '0.82rem' }}>\n              <code style={{ fontSize: '0.78rem' }}>{c.file}</code>\n              <span style={{ fontSize: '0.78rem', color: '#666', textAlign: 'right' }}>{c.importers} importers</span>\n            </div>\n          ))}\n        </div>\n      </section>\n\n      <footer style={{ marginTop: '1.5rem', paddingTop: '0.8rem', borderTop: '1px solid #e2e0db', fontSize: '0.78rem', color: '#666' }}>\n        Refresh: <code>scripts/inventory-project.sh</code>\n      </footer>\n    </div>\n  );\n}\n\n// ── Fixture: a populated inventory (mixed design system, real + dead components) ──\nconst FIXTURE: ProjectInventoryReport = {\n  generatedAt: '2026-05-31 14:30',\n  ranBy: 'inventory-project.sh',\n  libraries: { react: true, vite: true, tailwindV4: true, tailwindV3: false, shadcn: true, radix: true, baseui: false, r3f: false },\n  designSystem: {\n    dominant: 'tailwind-v4',\n    mixed: true,\n    mixedReason: 'Tailwind v4 @theme and shadcn cssVars both present',\n    tokenCounts: { 'tailwind-v4': 84, shadcn: 31, dtcg: 0, 'css-vars': 12 },\n  },\n  components: {\n    totalFiles: 38, realCount: 26, deadCount: 6,\n    real: [\n      { file: 'src/components/Button.tsx', importers: 22 },\n      { file: 'src/components/Card.tsx', importers: 17 },\n      { file: 'src/components/Input.tsx', importers: 14 },\n      { file: 'src/components/Modal.tsx', importers: 9 },\n      { file: 'src/components/Badge.tsx', importers: 8 },\n      { file: 'src/components/Avatar.tsx', importers: 6 },\n      { file: 'src/components/Tabs.tsx', importers: 5 },\n    ],\n    dead: [\n      { file: 'src/components/OldHero.tsx', importers: 0 },\n      { file: 'src/components/LegacyTable.tsx', importers: 0 },\n      { file: 'src/components/UnusedCarousel.tsx', importers: 0 },\n      { file: 'src/components/DraftBanner.tsx', importers: 0 },\n    ],\n  },\n  tokens: { totalDeclared: 127, usedCount: 103, orphanCount: 24, orphan: ['--color-accent-legacy', '--spacing-huge'] },\n  orphanStories: {\n    count: 2,\n    items: [\n      { story: 'src/stories/OldHero.stories.tsx', missing_import: '../components/OldHero' },\n      { story: 'src/stories/LegacyTable.stories.tsx', missing_import: '../components/LegacyTable' },\n    ],\n  },\n};\n\nexport default function Preview(): ReactElement {\n  return <ProjectInventory report={FIXTURE} />;\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 2024,
          "y": 2764
        },
        "size": {
          "width": 940,
          "height": 700
        },
        "rotation": 0,
        "zIndex": 21
      },
      {
        "id": "canvas-item-sbtier-flow",
        "type": "markdown",
        "title": "⑤ FLOW — app route map & user journey",
        "source": "## ⑤ FLOW — app route map & user journey\n\nAppFlowGraph  ·  JourneyGraph",
        "background": "#ffffff",
        "position": {
          "x": 160,
          "y": 3664
        },
        "size": {
          "width": 1400,
          "height": 96
        },
        "rotation": 0,
        "zIndex": 22
      },
      {
        "id": "canvas-item-sbwrapper-appflowgraph",
        "type": "html",
        "title": "AppFlowGraph",
        "sourceMode": "react",
        "sourceReact": "// Self-contained preview harness for AppFlowGraph wrapper.\n// Inlines the wrapper implementation (already dependency-free) + a realistic fixture.\nimport React, { useEffect, useMemo, useRef, useState } from \"react\"\nimport type { ComponentType, CSSProperties, PointerEvent as ReactPointerEvent, WheelEvent as ReactWheelEvent } from \"react\"\n\nexport type Role = \"public\" | \"student\" | \"teacher\" | \"system\" | string\nexport type EdgeKind = \"link\" | \"router\" | \"form\" | \"redirect\" | \"nav\"\nexport type Coverage = \"flow\" | \"story\" | \"partial\" | \"none\"\n\nexport type AppNode = {\n  id: string\n  label: string\n  role: Role\n  page?: string\n  storyId: string | null\n  coverage: Coverage\n  modals?: string[]\n  order: number\n  entry?: boolean\n}\n\nexport type AppEdge = { from: string; to: string; kind: EdgeKind; label: string; inFlow?: boolean }\nexport type AppGraph = { nodes: AppNode[]; edges: AppEdge[]; lanes?: Role[] }\n\ntype FlowIcon = ComponentType<{ size?: number; strokeWidth?: number; style?: CSSProperties }>\ninterface FlowIcons {\n  back?: FlowIcon\n  zoomIn?: FlowIcon\n  zoomOut?: FlowIcon\n  entry?: FlowIcon\n  modal?: FlowIcon\n  openStory?: FlowIcon\n}\nconst Svg = (p: { size?: number; strokeWidth?: number; style?: CSSProperties; d: string; fill?: boolean }) => (\n  <svg width={p.size ?? 14} height={p.size ?? 14} viewBox=\"0 0 24 24\" fill={p.fill ? \"currentColor\" : \"none\"}\n    stroke=\"currentColor\" strokeWidth={p.strokeWidth ?? 2} strokeLinecap=\"round\" strokeLinejoin=\"round\" style={p.style}>\n    <path d={p.d} />\n  </svg>\n)\nconst DEFAULT_ICONS: Required<FlowIcons> = {\n  back:      (p) => <Svg {...p} d=\"M19 12H5M12 19l-7-7 7-7\" />,\n  zoomIn:    (p) => <Svg {...p} d=\"M12 5v14M5 12h14\" />,\n  zoomOut:   (p) => <Svg {...p} d=\"M5 12h14\" />,\n  entry:     (p) => <Svg {...p} fill d=\"M8 5v14l11-7z\" />,\n  modal:     (p) => <Svg {...p} d=\"M3 5h18v14H3zM3 9h18\" />,\n  openStory: (p) => <Svg {...p} d=\"M7 17L17 7M9 7h8v8\" />,\n}\n\nconst LANE_LABEL: Record<string, string> = { public: \"Public\", student: \"Student\", teacher: \"Teacher\", system: \"System\" }\nconst laneLabel = (r: Role) => LANE_LABEL[r] ?? (r.charAt(0).toUpperCase() + r.slice(1))\n\nconst NODE_W = 216\nconst NODE_H = 56\nconst LANE_W = 300\nconst LANE_PITCH_MAX = 660\nconst ROW_H = 80\nconst HEADER_Y = 60\nconst MARGIN_X = 28\nconst RIGHT_PAD = 112\n\nconst F_W = 212\nconst F_NH = 62\nconst F_GAP = 22\nconst F_COL = 168\nconst HUE = 152\n\nconst COVERAGE_COLOR: Record<Coverage, string> = {\n  flow: `oklch(0.6 0.14 ${HUE})`,\n  story: \"oklch(0.6 0.11 245)\",\n  partial: \"oklch(0.74 0.14 78)\",\n  none: `oklch(0.62 0.015 ${HUE})`,\n}\nconst COVERAGE_LABEL: Record<Coverage, string> = {\n  flow: \"In a built flow\", story: \"Has a story\", partial: \"Partial story\", none: \"No story\",\n}\nconst EDGE_COLOR: Record<EdgeKind, string> = {\n  link: `oklch(0.56 0.015 ${HUE})`,\n  router: \"oklch(0.55 0.12 258)\",\n  form: \"oklch(0.66 0.14 72)\",\n  redirect: `oklch(0.58 0.14 ${HUE})`,\n  nav: \"oklch(0.62 0.06 300)\",\n}\nconst EDGE_LABEL: Record<EdgeKind, string> = { link: \"Link\", router: \"router.visit\", form: \"Form submit\", redirect: \"Server redirect\", nav: \"Sidebar nav\" }\nconst dashed = (k: EdgeKind) => k === \"router\" || k === \"form\" || k === \"nav\"\n\ntype LNode = { id: string; x: number; y: number; w: number; h: number; kind: \"screen\" | \"center\" | \"neighbor\"; node: AppNode; dim?: boolean }\ntype LEdge = { key: string; d: string; color: string; kind: EdgeKind; width: number; opacity: number; dash?: string; label?: string; lx?: number; ly?: number }\ntype LaneMeta = { role: Role; x: number; count: number }\ntype Layout = { width: number; height: number; nodes: LNode[]; edges: LEdge[]; lanes?: LaneMeta[]; participating?: Set<string>; signature: string }\n\nfunction activeLanes(nodes: AppNode[], declared?: Role[]): Role[] {\n  const order = declared && declared.length ? declared : [\"public\", \"student\", \"teacher\", \"system\"]\n  const present = Array.from(new Set(nodes.map((n) => n.role)))\n  return [...order.filter((r) => present.includes(r)), ...present.filter((r) => !order.includes(r))]\n}\n\ntype Side = \"L\" | \"R\"\ntype Pin = { e: AppEdge; a: LNode; b: LNode; self: boolean; sSide: Side; tSide: Side }\n\nfunction mapLayout(graph: AppGraph, lanes: Role[], kinds: Record<EdgeKind, boolean>, pitch: number): Layout {\n  const lane = new Map<string, number>()\n  const nodes: LNode[] = []\n  for (const n of graph.nodes) {\n    const li = Math.max(0, lanes.indexOf(n.role))\n    lane.set(n.id, li)\n    nodes.push({ id: n.id, x: MARGIN_X + li * pitch, y: HEADER_Y + n.order * ROW_H, w: NODE_W, h: NODE_H, kind: \"screen\", node: n })\n  }\n  const byId = new Map(nodes.map((n) => [n.id, n]))\n\n  const pins: Pin[] = []\n  const participating = new Set<string>()\n  for (const e of graph.edges) {\n    if (!kinds[e.kind]) continue\n    const a = byId.get(e.from), b = byId.get(e.to)\n    if (!a || !b) continue\n    participating.add(e.from)\n    participating.add(e.to)\n    if (a.id === b.id) { pins.push({ e, a, b, self: true, sSide: \"R\", tSide: \"R\" }); continue }\n    const al = lane.get(a.id)!, bl = lane.get(b.id)!\n    if (al === bl) pins.push({ e, a, b, self: false, sSide: \"R\", tSide: \"R\" })\n    else if (bl > al) pins.push({ e, a, b, self: false, sSide: \"R\", tSide: \"L\" })\n    else pins.push({ e, a, b, self: false, sSide: \"L\", tSide: \"R\" })\n  }\n\n  const akey = (id: string, s: Side) => `${id}|${s}`\n  const total = new Map<string, number>()\n  for (const p of pins) {\n    if (p.self) continue\n    total.set(akey(p.a.id, p.sSide), (total.get(akey(p.a.id, p.sSide)) ?? 0) + 1)\n    total.set(akey(p.b.id, p.tSide), (total.get(akey(p.b.id, p.tSide)) ?? 0) + 1)\n  }\n  const used = new Map<string, number>()\n  const slotY = (node: LNode, key: string) => {\n    const tt = total.get(key) ?? 1\n    const i = used.get(key) ?? 0\n    used.set(key, i + 1)\n    return node.y + (node.h * (i + 1)) / (tt + 1)\n  }\n  const sideX = (node: LNode, s: Side) => (s === \"R\" ? node.x + node.w : node.x)\n\n  const edges: LEdge[] = pins.map((p, i) => {\n    if (p.self) {\n      const x = p.a.x + p.a.w, cy = p.a.y + p.a.h / 2\n      return { key: `${i}`, d: `M ${x - 8} ${cy - 12} C ${x + 46} ${cy - 30}, ${x + 46} ${cy + 30}, ${x - 8} ${cy + 12}`, color: EDGE_COLOR[p.e.kind], kind: p.e.kind, width: 1.6, opacity: 0.75, dash: dashed(p.e.kind) ? \"5 4\" : undefined, label: p.e.label, lx: x + 34, ly: cy }\n    }\n    const sx = sideX(p.a, p.sSide), tx = sideX(p.b, p.tSide)\n    const sy = slotY(p.a, akey(p.a.id, p.sSide)), ty = slotY(p.b, akey(p.b.id, p.tSide))\n    let d: string\n    if (p.sSide === \"R\" && p.tSide === \"R\") {\n      const bow = Math.max(sx, tx) + 52\n      d = `M ${sx} ${sy} C ${bow} ${sy}, ${bow} ${ty}, ${tx} ${ty}`\n    } else {\n      const c = Math.max(48, Math.abs(tx - sx) / 2)\n      const c1 = p.sSide === \"R\" ? sx + c : sx - c\n      const c2 = p.tSide === \"L\" ? tx - c : tx + c\n      d = `M ${sx} ${sy} C ${c1} ${sy}, ${c2} ${ty}, ${tx} ${ty}`\n    }\n    return { key: `${i}`, d, color: EDGE_COLOR[p.e.kind], kind: p.e.kind, width: p.e.inFlow ? 2.2 : 1.3, opacity: p.e.inFlow ? 0.88 : 0.32, dash: dashed(p.e.kind) ? \"5 4\" : undefined, label: p.e.label, lx: (sx + tx) / 2, ly: (sy + ty) / 2 }\n  })\n\n  const counts = lanes.map((r) => graph.nodes.filter((n) => n.role === r).length)\n  return {\n    width: MARGIN_X * 2 + (lanes.length - 1) * pitch + NODE_W + RIGHT_PAD,\n    height: HEADER_Y + Math.max(1, ...counts) * ROW_H + 24,\n    nodes, edges,\n    lanes: lanes.map((role, i) => ({ role, x: MARGIN_X + i * pitch, count: counts[i] })),\n    participating,\n    signature: `map:${lanes.join(\",\")}:${pitch}:${Object.values(kinds).join(\"\")}`,\n  }\n}\n\nfunction centerCardHeight(n: AppNode): number {\n  const base = 104\n  const modals = n.modals?.length ? n.modals.length * 28 + 12 : 0\n  const story = n.storyId ? 40 : 0\n  return base + modals + story\n}\n\nfunction egoLayout(graph: AppGraph, selId: string, kinds: Record<EdgeKind, boolean>, col: number): Layout {\n  const byNode = new Map(graph.nodes.map((n) => [n.id, n]))\n  const sel = byNode.get(selId)!\n  const inc = graph.edges.filter((e) => e.to === selId && e.from !== selId && kinds[e.kind])\n  const out = graph.edges.filter((e) => e.from === selId && e.to !== selId && kinds[e.kind])\n  const self = graph.edges.filter((e) => e.from === selId && e.to === selId && kinds[e.kind])\n\n  const centerH = centerCardHeight(sel)\n  const leftStack = inc.length * F_NH + Math.max(0, inc.length - 1) * F_GAP\n  const rightStack = out.length * F_NH + Math.max(0, out.length - 1) * F_GAP\n  const contentH = Math.max(leftStack, rightStack, centerH) + 96\n  const cx0 = 40 + F_W + col\n  const cy = contentH / 2\n  const center: LNode = { id: sel.id, x: cx0, y: cy - centerH / 2, w: F_W, h: centerH, kind: \"center\", node: sel }\n  const nodes: LNode[] = [center]\n  const edges: LEdge[] = []\n\n  const cLeft = { x: center.x, y: cy }\n  const cRight = { x: center.x + center.w, y: cy }\n\n  inc.forEach((e, i) => {\n    const ny = cy - leftStack / 2 + i * (F_NH + F_GAP) + F_NH / 2\n    const nx = center.x - col - F_W\n    nodes.push({ id: `in:${e.from}:${i}`, x: nx, y: ny - F_NH / 2, w: F_W, h: F_NH, kind: \"neighbor\", node: byNode.get(e.from)! })\n    const sx = nx + F_W, sy = ny\n    const c = (cLeft.x - sx) / 2\n    edges.push({ key: `in${i}`, d: `M ${sx} ${sy} C ${sx + c} ${sy}, ${cLeft.x - c} ${cLeft.y}, ${cLeft.x} ${cLeft.y}`, color: EDGE_COLOR[e.kind], kind: e.kind, width: e.inFlow ? 2.6 : 1.8, opacity: 0.9, dash: dashed(e.kind) ? \"5 4\" : undefined, label: e.label, lx: (sx + cLeft.x) / 2, ly: (sy + cLeft.y) / 2 })\n  })\n  out.forEach((e, i) => {\n    const ny = cy - rightStack / 2 + i * (F_NH + F_GAP) + F_NH / 2\n    const nx = center.x + center.w + col\n    nodes.push({ id: `out:${e.to}:${i}`, x: nx, y: ny - F_NH / 2, w: F_W, h: F_NH, kind: \"neighbor\", node: byNode.get(e.to)! })\n    const tx = nx, ty = ny\n    const c = (tx - cRight.x) / 2\n    edges.push({ key: `out${i}`, d: `M ${cRight.x} ${cRight.y} C ${cRight.x + c} ${cRight.y}, ${tx - c} ${ty}, ${tx} ${ty}`, color: EDGE_COLOR[e.kind], kind: e.kind, width: e.inFlow ? 2.6 : 1.8, opacity: 0.9, dash: dashed(e.kind) ? \"5 4\" : undefined, label: e.label, lx: (cRight.x + tx) / 2, ly: (cRight.y + ty) / 2 })\n  })\n  self.forEach((e, i) => {\n    const x = center.x + center.w / 2, top = center.y\n    edges.push({ key: `self${i}`, d: `M ${x - 18} ${top} C ${x - 30} ${top - 46}, ${x + 30} ${top - 46}, ${x + 18} ${top}`, color: EDGE_COLOR[e.kind], kind: e.kind, width: 1.8, opacity: 0.9, dash: dashed(e.kind) ? \"5 4\" : undefined, label: e.label, lx: x, ly: top - 40 })\n  })\n\n  return {\n    width: center.x + center.w + col + F_W + 40,\n    height: contentH,\n    nodes, edges,\n    signature: `ego:${selId}:${col}:${Object.values(kinds).join(\"\")}`,\n  }\n}\n\nfunction goToStory(storyId: string): void {\n  const top = window.parent ?? window\n  try {\n    top.location.href = `${top.location.origin}/?path=/story/${storyId}`\n  } catch {\n    window.location.href = `/?path=/story/${storyId}`\n  }\n}\n\nconst EASE = \"cubic-bezier(0.22, 1, 0.36, 1)\"\nconst panel: CSSProperties = {\n  position: \"absolute\", background: `oklch(0.99 0.004 ${HUE})`, border: `1px solid oklch(0.9 0.012 ${HUE})`,\n  borderRadius: 10, padding: \"9px 11px\", fontSize: 12, color: `oklch(0.3 0.02 ${HUE})`,\n  boxShadow: `0 6px 22px oklch(0.4 0.03 ${HUE} / 0.12)`,\n}\nconst btn: CSSProperties = {\n  display: \"inline-flex\", alignItems: \"center\", gap: 4, padding: \"4px 9px\", fontSize: 11.5,\n  borderRadius: 7, border: `1px solid oklch(0.88 0.012 ${HUE})`, background: `oklch(0.99 0.004 ${HUE})`,\n  color: `oklch(0.38 0.02 ${HUE})`, cursor: \"pointer\", fontFamily: \"inherit\",\n}\nconst chip: CSSProperties = {\n  display: \"inline-flex\", alignItems: \"center\", gap: 5, padding: \"2px 7px\", borderRadius: 999,\n  border: `1px solid oklch(0.9 0.012 ${HUE})`, fontSize: 11, background: `oklch(0.985 0.005 ${HUE})`,\n}\n\nfunction AppFlowGraph({ graph, icons }: { graph: AppGraph; icons?: FlowIcons }) {\n  const ic = { ...DEFAULT_ICONS, ...icons }\n  const lanes = useMemo(() => activeLanes(graph.nodes, graph.lanes), [graph])\n  const [mode, setMode] = useState<\"map\" | \"focus\">(\"map\")\n  const [sel, setSel] = useState<string | null>(null)\n  const [kinds, setKinds] = useState<Record<EdgeKind, boolean>>({ link: true, router: true, form: true, redirect: true, nav: true })\n  const [view, setView] = useState({ k: 0.8, tx: 16, ty: 16 })\n  const [cw, setCw] = useState(1200)\n  const wrapRef = useRef<HTMLDivElement>(null)\n  const size = useRef({ w: 1000, h: 600 })\n  const drag = useRef<{ x: number; y: number; tx: number; ty: number } | null>(null)\n\n  const pitch = useMemo(\n    () => Math.max(LANE_W, Math.min(LANE_PITCH_MAX, Math.floor((cw - 2 * MARGIN_X - NODE_W - RIGHT_PAD) / Math.max(1, lanes.length - 1)))),\n    [cw, lanes.length],\n  )\n  const focusCol = useMemo(() => Math.max(F_COL, Math.min(460, Math.floor((cw - 80 - 3 * F_W) / 2))), [cw])\n\n  const layout = useMemo<Layout>(\n    () => (mode === \"focus\" && sel ? egoLayout(graph, sel, kinds, focusCol) : mapLayout(graph, lanes, kinds, pitch)),\n    [mode, sel, graph, lanes, kinds, pitch, focusCol],\n  )\n\n  function fitFor(l: Layout, focus: boolean) {\n    const { w, h } = size.current\n    if (focus) {\n      const k = Math.min(1.15, Math.max(0.32, Math.min((w - 32) / l.width, (h - 32) / l.height)))\n      setView({ k, tx: (w - l.width * k) / 2, ty: Math.max(12, (h - l.height * k) / 2) })\n    } else {\n      const k = Math.min(1.2, Math.max(0.34, (w - 24) / l.width))\n      setView({ k, tx: (w - l.width * k) / 2, ty: 14 })\n    }\n  }\n  useEffect(() => { fitFor(layout, mode === \"focus\") /* eslint-disable-next-line */ }, [layout.signature])\n  useEffect(() => {\n    const el = wrapRef.current\n    if (!el || typeof ResizeObserver === \"undefined\") return\n    const ro = new ResizeObserver(() => {\n      size.current = { w: el.clientWidth, h: el.clientHeight }\n      setCw(el.clientWidth)\n    })\n    ro.observe(el)\n    size.current = { w: el.clientWidth, h: el.clientHeight }\n    setCw(el.clientWidth)\n    fitFor(layout, mode === \"focus\")\n    return () => ro.disconnect()\n    // eslint-disable-next-line\n  }, [])\n\n  function onWheel(e: ReactWheelEvent) {\n    e.preventDefault()\n    const rect = wrapRef.current?.getBoundingClientRect()\n    if (!rect) return\n    const px = e.clientX - rect.left, py = e.clientY - rect.top\n    const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12\n    setView((v) => {\n      const k = Math.min(2.4, Math.max(0.25, v.k * factor))\n      const wx = (px - v.tx) / v.k, wy = (py - v.ty) / v.k\n      return { k, tx: px - wx * k, ty: py - wy * k }\n    })\n  }\n  function onPointerDown(e: ReactPointerEvent) {\n    if ((e.target as HTMLElement).closest(\"[data-node]\")) return\n    drag.current = { x: e.clientX, y: e.clientY, tx: view.tx, ty: view.ty }\n    ;(e.currentTarget as HTMLElement).setPointerCapture(e.pointerId)\n  }\n  function onPointerMove(e: ReactPointerEvent) {\n    if (!drag.current) return\n    setView((v) => ({ ...v, tx: drag.current!.tx + (e.clientX - drag.current!.x), ty: drag.current!.ty + (e.clientY - drag.current!.y) }))\n  }\n  function onPointerUp() { drag.current = null }\n  function zoom(f: number) { setView((v) => ({ ...v, k: Math.min(2.4, Math.max(0.25, v.k * f)) })) }\n\n  function openNode(id: string) { setSel(id); setMode(\"focus\") }\n  function backToMap() { setMode(\"map\") }\n\n  const cov = (c: Coverage) => graph.nodes.filter((n) => n.coverage === c).length\n  const selNode = sel ? graph.nodes.find((n) => n.id === sel) : null\n\n  const isFocus = mode === \"focus\" && !!sel\n  const allActive = Object.values(kinds).every(Boolean)\n  const spotlight = !isFocus && !allActive\n  const showEdgeLabels = isFocus || layout.edges.length <= 12\n  const activeKindNames = (Object.keys(kinds) as EdgeKind[]).filter((k) => kinds[k])\n\n  return (\n    <div style={{ fontFamily: \"ui-sans-serif, system-ui, sans-serif\", color: `oklch(0.28 0.02 ${HUE})`, display: \"flex\", flexDirection: \"column\", height: \"100%\", minHeight: 0 }}>\n      <div style={{ display: \"flex\", alignItems: \"baseline\", justifyContent: \"space-between\", flexWrap: \"wrap\", gap: 12, marginBottom: 8 }}>\n        <div>\n          <div style={{ fontSize: 17, fontWeight: 650, letterSpacing: \"-0.01em\" }}>App route map</div>\n          <div style={{ fontSize: 12.5, color: `oklch(0.5 0.02 ${HUE})`, marginTop: 2 }}>\n            {isFocus\n              ? \"Connections for one screen · click a neighbour to walk, drag to pan, scroll to zoom\"\n              : spotlight\n                ? `${activeKindNames.map((k) => EDGE_LABEL[k]).join(\" + \")} · ${layout.participating?.size ?? 0} of ${graph.nodes.length} screens · click one to expand`\n                : `${graph.nodes.length} screens · ${graph.edges.length} transitions · click a screen to expand, or filter an edge type to spotlight its screens`}\n          </div>\n        </div>\n        <div style={{ display: \"flex\", gap: 6, alignItems: \"center\" }}>\n          {([\"flow\", \"story\", \"partial\"] as Coverage[]).map((c) => (\n            <span key={c} style={chip}>\n              <span style={{ width: 9, height: 9, borderRadius: 999, background: COVERAGE_COLOR[c] }} />\n              {cov(c)} {COVERAGE_LABEL[c].toLowerCase()}\n            </span>\n          ))}\n        </div>\n      </div>\n\n      <div style={{ display: \"flex\", gap: 8, alignItems: \"center\", flexWrap: \"wrap\", marginBottom: 8 }}>\n        {mode === \"focus\" && (\n          <>\n            <button onClick={backToMap} style={{ ...btn, fontWeight: 600 }}><ic.back size={13} /> Map</button>\n            <span style={{ ...chip, gap: 6 }}>\n              <span style={{ width: 9, height: 9, borderRadius: 999, background: COVERAGE_COLOR[selNode?.coverage ?? \"none\"] }} />\n              <strong style={{ fontWeight: 600 }}>{selNode?.label}</strong>\n            </span>\n            <span style={{ width: 1, height: 18, background: `oklch(0.9 0.012 ${HUE})` }} />\n          </>\n        )}\n        <div style={{ display: \"flex\", gap: 4 }}>\n          <button onClick={() => zoom(1.15)} style={btn} title=\"Zoom in\"><ic.zoomIn size={14} /></button>\n          <button onClick={() => zoom(1 / 1.15)} style={btn} title=\"Zoom out\"><ic.zoomOut size={14} /></button>\n          <button onClick={() => fitFor(layout, true)} style={btn} title=\"Zoom to fit everything\">Fit all</button>\n          <button onClick={() => fitFor(layout, false)} style={btn} title=\"Fill width\">Width</button>\n        </div>\n        <span style={{ width: 1, height: 18, background: `oklch(0.9 0.012 ${HUE})` }} />\n        <span style={{ fontSize: 11.5, color: `oklch(0.55 0.02 ${HUE})` }}>Edges:</span>\n        {(Object.keys(EDGE_LABEL) as EdgeKind[]).map((k) => (\n          <button key={k} onClick={() => setKinds((s) => ({ ...s, [k]: !s[k] }))} style={{ ...btn, opacity: kinds[k] ? 1 : 0.4, borderColor: EDGE_COLOR[k], color: EDGE_COLOR[k] }}>\n            <span style={{ width: 14, borderTop: `2px ${dashed(k) ? \"dashed\" : \"solid\"} ${EDGE_COLOR[k]}`, display: \"inline-block\", marginRight: 5, verticalAlign: \"middle\" }} />\n            {EDGE_LABEL[k]}\n          </button>\n        ))}\n      </div>\n\n      <div\n        ref={wrapRef}\n        onWheel={onWheel}\n        onPointerDown={onPointerDown}\n        onPointerMove={onPointerMove}\n        onPointerUp={onPointerUp}\n        style={{\n          position: \"relative\", flex: 1, minHeight: 0, overflow: \"hidden\", cursor: drag.current ? \"grabbing\" : \"grab\",\n          border: `1px solid oklch(0.9 0.012 ${HUE})`, borderRadius: 12, background: `oklch(0.992 0.003 ${HUE})`,\n          backgroundImage: `radial-gradient(oklch(0.9 0.012 ${HUE}) 0.8px, transparent 0.8px)`, backgroundSize: \"22px 22px\", touchAction: \"none\",\n        }}\n      >\n        <svg width={layout.width} height={layout.height} style={{ transform: `translate(${view.tx}px, ${view.ty}px) scale(${view.k})`, transformOrigin: \"0 0\", transition: drag.current ? \"none\" : `transform 0.42s ${EASE}` }}>\n          <defs>\n            {(Object.keys(EDGE_COLOR) as EdgeKind[]).map((k) => (\n              <marker key={k} id={`arr-${k}`} viewBox=\"0 0 8 8\" refX=\"7\" refY=\"4\" markerWidth=\"7\" markerHeight=\"7\" orient=\"auto-start-reverse\">\n                <path d=\"M0,0 L8,4 L0,8 z\" fill={EDGE_COLOR[k]} />\n              </marker>\n            ))}\n          </defs>\n\n          {layout.lanes?.map((lm, i) => (\n            <g key={lm.role}>\n              <rect x={lm.x - 12} y={26} width={NODE_W + 24} height={layout.height - 38} rx={12} fill={i % 2 ? `oklch(0.985 0.007 ${HUE})` : `oklch(0.978 0.009 ${HUE})`} stroke={`oklch(0.93 0.012 ${HUE})`} />\n              <text x={lm.x + NODE_W / 2} y={18} textAnchor=\"middle\" fontSize={12.5} fontWeight={650} fill={`oklch(0.5 0.03 ${HUE})`} letterSpacing=\"0.04em\">\n                {laneLabel(lm.role).toUpperCase()} · {lm.count}\n              </text>\n            </g>\n          ))}\n\n          {layout.edges.map((e) => (\n            <g key={e.key} style={{ transition: `opacity 0.3s ${EASE}` }}>\n              <path d={e.d} fill=\"none\" stroke={e.color} strokeWidth={e.width} strokeDasharray={e.dash} opacity={e.opacity} markerEnd={`url(#arr-${e.kind})`} />\n              {showEdgeLabels && e.label && e.lx != null && e.ly != null && (\n                <g transform={`translate(${e.lx}, ${e.ly})`}>\n                  <rect x={-(e.label.length * 3.2 + 8)} y={-9} width={e.label.length * 6.4 + 16} height={18} rx={9} fill={`oklch(0.995 0.003 ${HUE})`} stroke={`oklch(0.9 0.012 ${HUE})`} />\n                  <text textAnchor=\"middle\" y={4} fontSize={10.5} fill={`oklch(0.42 0.04 ${HUE})`}>{e.label}</text>\n                </g>\n              )}\n            </g>\n          ))}\n\n          {layout.nodes.map((ln) => {\n            const dim = spotlight && !!layout.participating && !layout.participating.has(ln.id)\n            return (\n              <g key={ln.id} transform={`translate(${ln.x}, ${ln.y})`} style={{ transition: drag.current ? \"none\" : `transform 0.42s ${EASE}, opacity 0.3s ${EASE}`, opacity: dim ? 0.2 : 1 }}>\n                <foreignObject width={ln.w} height={ln.h} style={{ overflow: \"visible\" }}>\n                  {ln.kind === \"center\" ? <CenterCard n={ln.node} ic={ic} /> : <ScreenCard n={ln.node} w={ln.w} h={ln.h} ic={ic} onOpen={() => openNode(ln.node.id)} />}\n                </foreignObject>\n              </g>\n            )\n          })}\n        </svg>\n\n        <div style={{ ...panel, right: 12, bottom: 12, display: \"flex\", flexDirection: \"column\", gap: 5 }}>\n          <div style={{ fontWeight: 600, fontSize: 11, color: `oklch(0.45 0.02 ${HUE})` }}>Coverage</div>\n          {([\"flow\", \"story\", \"partial\", \"none\"] as Coverage[]).map((c) => (\n            <div key={c} style={{ display: \"flex\", alignItems: \"center\", gap: 6 }}>\n              <span style={{ width: 9, height: 9, borderRadius: 999, background: COVERAGE_COLOR[c] }} />\n              <span style={{ fontSize: 11 }}>{COVERAGE_LABEL[c]}</span>\n            </div>\n          ))}\n        </div>\n      </div>\n    </div>\n  )\n}\n\nfunction ScreenCard({ n, w, h, ic, onOpen }: { n: AppNode; w: number; h: number; ic: Required<FlowIcons>; onOpen: () => void }) {\n  return (\n    <div\n      data-node={n.id}\n      onClick={onOpen}\n      style={{\n        boxSizing: \"border-box\", height: h, width: w, padding: \"7px 9px\", borderRadius: 10, cursor: \"pointer\",\n        background: `oklch(0.995 0.003 ${HUE})`, border: `1.5px solid oklch(0.88 0.012 ${HUE})`,\n        boxShadow: `0 1px 2px oklch(0.4 0.03 ${HUE} / 0.06)`, display: \"flex\", flexDirection: \"column\", gap: 2,\n      }}\n    >\n      <div style={{ display: \"flex\", alignItems: \"center\", gap: 6 }}>\n        <span style={{ width: 8, height: 8, borderRadius: 999, background: COVERAGE_COLOR[n.coverage], flex: \"0 0 auto\" }} />\n        <span style={{ fontSize: 12.5, fontWeight: 600, lineHeight: 1.1, color: `oklch(0.26 0.02 ${HUE})`, overflow: \"hidden\", textOverflow: \"ellipsis\", whiteSpace: \"nowrap\" }}>{n.label}</span>\n        {n.entry && <span title=\"Entry point\" style={{ marginLeft: \"auto\", color: `oklch(0.6 0.03 ${HUE})`, display: \"inline-flex\" }}><ic.entry size={11} /></span>}\n      </div>\n      <div style={{ display: \"flex\", alignItems: \"center\", gap: 6 }}>\n        <span style={{ fontFamily: \"ui-monospace, monospace\", fontSize: 10.5, color: `oklch(0.55 0.02 ${HUE})`, overflow: \"hidden\", textOverflow: \"ellipsis\", whiteSpace: \"nowrap\" }}>{n.id}</span>\n        {n.modals?.length ? <span title={n.modals.join(\", \")} style={{ marginLeft: \"auto\", fontSize: 9.5, color: \"oklch(0.55 0.1 300)\", flex: \"0 0 auto\", display: \"inline-flex\", alignItems: \"center\", gap: 3 }}><ic.modal size={11} /> {n.modals.length}</span> : null}\n      </div>\n    </div>\n  )\n}\n\nfunction CenterCard({ n, ic }: { n: AppNode; ic: Required<FlowIcons> }) {\n  return (\n    <div\n      data-node={n.id}\n      style={{\n        boxSizing: \"border-box\", width: F_W, padding: \"12px 13px\", borderRadius: 13,\n        background: `oklch(0.995 0.003 ${HUE})`, border: `2px solid ${COVERAGE_COLOR[n.coverage]}`,\n        boxShadow: `0 8px 26px oklch(0.4 0.04 ${HUE} / 0.16)`, display: \"flex\", flexDirection: \"column\", gap: 7,\n      }}\n    >\n      <div style={{ fontSize: 14.5, fontWeight: 650, lineHeight: 1.15, color: `oklch(0.22 0.02 ${HUE})` }}>{n.label}</div>\n      <div style={{ fontFamily: \"ui-monospace, monospace\", fontSize: 10.5, lineHeight: 1.35, color: `oklch(0.5 0.02 ${HUE})`, wordBreak: \"break-all\" }}>{n.id}</div>\n      <div style={{ display: \"flex\", flexWrap: \"wrap\", gap: 4 }}>\n        <span style={{ ...chip, gap: 5, fontSize: 10.5 }}>\n          <span style={{ width: 8, height: 8, borderRadius: 999, background: COVERAGE_COLOR[n.coverage] }} />\n          {COVERAGE_LABEL[n.coverage]}\n        </span>\n        {n.entry && <span style={{ ...chip, fontSize: 10.5, color: `oklch(0.45 0.04 ${HUE})`, gap: 4 }}><ic.entry size={11} /> Entry</span>}\n      </div>\n      {n.modals?.length ? (\n        <div style={{ display: \"flex\", flexWrap: \"wrap\", gap: 4 }}>\n          {n.modals.map((m) => <span key={m} style={{ ...chip, fontSize: 10, color: \"oklch(0.5 0.1 300)\", gap: 4 }}><ic.modal size={10} /> {m}</span>)}\n        </div>\n      ) : null}\n      {n.storyId && (\n        <button onClick={() => goToStory(n.storyId!)} style={{ ...btn, width: \"100%\", justifyContent: \"center\", color: \"oklch(0.4 0.1 245)\", borderColor: \"oklch(0.8 0.05 245)\", marginTop: 1, gap: 5 }}>Open story <ic.openStory size={12} /></button>\n      )}\n    </div>\n  )\n}\n\n// ── Fixture: a small course-platform app graph (8 screens, 11 transitions) ──\nconst FIXTURE: AppGraph = {\n  lanes: [\"public\", \"student\", \"teacher\", \"system\"],\n  nodes: [\n    { id: \"/\", label: \"Landing\", role: \"public\", storyId: \"pages-landing--default\", coverage: \"story\", order: 0, entry: true },\n    { id: \"/login\", label: \"Login\", role: \"public\", storyId: \"pages-login--default\", coverage: \"flow\", order: 1, entry: true, modals: [\"Forgot password\"] },\n    { id: \"/courses\", label: \"Course catalog\", role: \"student\", storyId: \"pages-catalog--default\", coverage: \"flow\", order: 0 },\n    { id: \"/courses/:id\", label: \"Course detail\", role: \"student\", storyId: \"pages-course--default\", coverage: \"partial\", order: 1, modals: [\"Enroll\", \"Share\"] },\n    { id: \"/dashboard\", label: \"Student dashboard\", role: \"student\", storyId: \"pages-dashboard--default\", coverage: \"story\", order: 2 },\n    { id: \"/teach\", label: \"Teacher home\", role: \"teacher\", storyId: \"pages-teach--default\", coverage: \"story\", order: 0 },\n    { id: \"/teach/new\", label: \"Create course\", role: \"teacher\", storyId: null, coverage: \"none\", order: 1, modals: [\"Discard draft\"] },\n    { id: \"/admin/jobs\", label: \"Job queue\", role: \"system\", storyId: null, coverage: \"none\", order: 0 },\n  ],\n  edges: [\n    { from: \"/\", to: \"/login\", kind: \"link\", label: \"Sign in\", inFlow: true },\n    { from: \"/login\", to: \"/dashboard\", kind: \"redirect\", label: \"On success\", inFlow: true },\n    { from: \"/dashboard\", to: \"/courses\", kind: \"nav\", label: \"Browse\" },\n    { from: \"/courses\", to: \"/courses/:id\", kind: \"link\", label: \"Open course\", inFlow: true },\n    { from: \"/courses/:id\", to: \"/dashboard\", kind: \"form\", label: \"Enroll\", inFlow: true },\n    { from: \"/dashboard\", to: \"/teach\", kind: \"nav\", label: \"Switch role\" },\n    { from: \"/teach\", to: \"/teach/new\", kind: \"link\", label: \"New course\" },\n    { from: \"/teach/new\", to: \"/teach\", kind: \"form\", label: \"Publish\" },\n    { from: \"/teach/new\", to: \"/admin/jobs\", kind: \"router\", label: \"Queue render\" },\n    { from: \"/\", to: \"/courses\", kind: \"link\", label: \"Explore\" },\n    { from: \"/courses/:id\", to: \"/courses/:id\", kind: \"router\", label: \"Filter\" },\n  ],\n}\n\nexport default function Preview(): React.ReactElement {\n  return (\n    <div style={{ height: 640, padding: 16 }}>\n      <AppFlowGraph graph={FIXTURE} />\n    </div>\n  )\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 160,
          "y": 3800
        },
        "size": {
          "width": 1180,
          "height": 680
        },
        "rotation": 0,
        "zIndex": 23
      },
      {
        "id": "canvas-item-sbwrapper-journeygraph",
        "type": "html",
        "title": "JourneyGraph",
        "sourceMode": "react",
        "sourceReact": "// Self-contained preview harness for JourneyGraph wrapper.\nimport React from \"react\"\nimport type { ComponentType, CSSProperties, ReactElement } from \"react\"\n\ntype JourneyStepKind = \"screen\" | \"action\" | \"modal\" | \"end\"\n\ninterface JourneyStep {\n  label: string\n  kind: JourneyStepKind\n  detail?: string\n  storyId?: string\n}\n\ninterface Journey {\n  title: string\n  role: string\n  entry: string\n  steps: JourneyStep[]\n  testable?: string\n}\n\ntype FlowIcon = ComponentType<{ size?: number; strokeWidth?: number; style?: CSSProperties }>\ninterface JourneyIcons {\n  screen?: FlowIcon\n  action?: FlowIcon\n  modal?: FlowIcon\n  end?: FlowIcon\n  link?: FlowIcon\n}\nconst Svg = (p: { size?: number; strokeWidth?: number; style?: CSSProperties; d: string }) => (\n  <svg width={p.size ?? 16} height={p.size ?? 16} viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"\n    strokeWidth={p.strokeWidth ?? 2} strokeLinecap=\"round\" strokeLinejoin=\"round\" style={p.style}>\n    <path d={p.d} />\n  </svg>\n)\nconst DEFAULT_ICONS: Required<JourneyIcons> = {\n  screen: (p) => <Svg {...p} d=\"M3 4h18v12H3zM8 20h8M12 16v4\" />,\n  action: (p) => <Svg {...p} d=\"M9 3v12l3-3 2 5 2-1-2-5h4z\" />,\n  modal:  (p) => <Svg {...p} d=\"M12 3l9 5-9 5-9-5zM3 13l9 5 9-5\" />,\n  end:    (p) => <Svg {...p} d=\"M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />,\n  link:   (p) => <Svg {...p} d=\"M7 17L17 7M9 7h8v8\" />,\n}\n\nconst T = {\n  surface: \"oklch(0.99 0.004 155)\",\n  line: \"oklch(0.9 0.01 155)\",\n  textStrong: \"oklch(0.28 0.02 155)\",\n  textMuted: \"oklch(0.48 0.022 155)\",\n  brand: \"oklch(0.5 0.09 152)\",\n  mono: \"ui-monospace, SFMono-Regular, Menlo, monospace\",\n  sans: \"ui-sans-serif, system-ui, sans-serif\",\n}\n\nconst KIND_META: Record<JourneyStepKind, { slot: keyof JourneyIcons; label: string; tint: string; ring: string }> = {\n  screen: { slot: \"screen\", label: \"screen\", tint: \"oklch(0.95 0.03 152)\", ring: \"oklch(0.78 0.06 152)\" },\n  action: { slot: \"action\", label: \"action\", tint: \"oklch(0.97 0.006 155)\", ring: T.line },\n  modal:  { slot: \"modal\",  label: \"modal\",  tint: \"oklch(0.96 0.03 85)\",  ring: \"oklch(0.82 0.07 85)\" },\n  end:    { slot: \"end\",    label: \"done\",   tint: \"oklch(0.95 0.04 152)\", ring: \"oklch(0.7 0.1 152)\" },\n}\n\nfunction goToStory(storyId: string): void {\n  const top = window.parent ?? window\n  try {\n    top.location.href = `${top.location.origin}/?path=/story/${storyId}`\n  } catch {\n    window.location.href = `/?path=/story/${storyId}`\n  }\n}\n\nfunction Chip({ children }: { children: string }): ReactElement {\n  return (\n    <span style={{ fontFamily: T.mono, fontSize: 11, color: T.textMuted, border: `1px solid ${T.line}`, borderRadius: 6, padding: \"1px 6px\", whiteSpace: \"nowrap\" }}>\n      {children}\n    </span>\n  )\n}\n\nfunction JourneyGraph({ journey, icons }: { journey: Journey; icons?: JourneyIcons }): ReactElement {\n  const ic = { ...DEFAULT_ICONS, ...icons }\n  const Link = ic.link\n  return (\n    <div style={{ fontFamily: T.sans, background: T.surface, border: `1px solid ${T.line}`, borderRadius: 14, padding: 20, color: T.textStrong }}>\n      <div style={{ display: \"flex\", flexWrap: \"wrap\", gap: 8, alignItems: \"baseline\", marginBottom: 16 }}>\n        <span style={{ fontSize: 15, fontWeight: 700 }}>{journey.title}</span>\n        <Chip>{`role: ${journey.role}`}</Chip>\n        <Chip>{`entry: ${journey.entry}`}</Chip>\n        <span style={{ marginLeft: \"auto\", fontFamily: T.mono, fontSize: 11, color: T.textMuted }}>\n          {journey.steps.length} steps captured\n        </span>\n      </div>\n\n      <div style={{ fontSize: 12, color: T.textMuted, marginBottom: 14, display: \"flex\", gap: 6, alignItems: \"center\" }}>\n        <span style={{ color: T.brand, display: \"inline-flex\" }}><Link size={13} strokeWidth={2.5} /></span>\n        <span>Click any underlined step to open that exact state in Storybook.</span>\n      </div>\n\n      <ol style={{ listStyle: \"none\", margin: 0, padding: 0 }}>\n        {journey.steps.map((s, i) => {\n          const meta = KIND_META[s.kind]\n          const Icon = ic[meta.slot]\n          const last = i === journey.steps.length - 1\n          return (\n            <li key={i} style={{ display: \"grid\", gridTemplateColumns: \"auto 1fr\", gap: 14 }}>\n              <div style={{ display: \"flex\", flexDirection: \"column\", alignItems: \"center\" }}>\n                <span style={{ display: \"grid\", placeItems: \"center\", width: 34, height: 34, borderRadius: \"50%\", background: meta.tint, border: `1.5px solid ${meta.ring}`, color: T.textStrong, flexShrink: 0 }}>\n                  <Icon size={16} strokeWidth={2} />\n                </span>\n                {!last && <span style={{ width: 2, flex: 1, minHeight: 22, background: T.line }} />}\n              </div>\n\n              <div style={{ paddingBottom: last ? 0 : 16 }}>\n                <div style={{ display: \"flex\", alignItems: \"center\", gap: 8 }}>\n                  <span style={{ fontFamily: T.mono, fontSize: 11, color: T.textMuted }}>{String(i + 1).padStart(2, \"0\")}</span>\n                  {s.storyId ? (\n                    <button type=\"button\" onClick={() => goToStory(s.storyId!)} title=\"Open this state in Storybook\"\n                      style={{ all: \"unset\", cursor: \"pointer\", fontWeight: 600, fontSize: 14, color: T.brand, display: \"inline-flex\", alignItems: \"center\", gap: 4, textDecoration: \"underline\", textUnderlineOffset: 2 }}>\n                      {s.label}\n                      <Link size={13} strokeWidth={2.5} />\n                    </button>\n                  ) : (\n                    <span style={{ fontWeight: 600, fontSize: 14 }}>{s.label}</span>\n                  )}\n                  <span style={{ fontFamily: T.mono, fontSize: 10, color: T.textMuted, textTransform: \"uppercase\", letterSpacing: 0.4 }}>{meta.label}</span>\n                </div>\n                {s.detail && <div style={{ marginTop: 4 }}><Chip>{s.detail}</Chip></div>}\n              </div>\n            </li>\n          )\n        })}\n      </ol>\n\n      {journey.testable && (\n        <div style={{ marginTop: 16, paddingTop: 14, borderTop: `1px solid ${T.line}`, display: \"flex\", gap: 8, alignItems: \"center\", color: T.textMuted, fontSize: 12 }}>\n          <span><strong style={{ color: T.textStrong, fontWeight: 600 }}>Notes:</strong> {journey.testable}</span>\n        </div>\n      )}\n    </div>\n  )\n}\n\n// ── Fixture: \"Student enrolls in a course\" journey (7 steps) ──\nconst FIXTURE: Journey = {\n  title: \"Student enrolls in a course\",\n  role: \"student\",\n  entry: \"/login\",\n  testable: \"Enroll modal + payment confirmation are exercisable in isolation.\",\n  steps: [\n    { label: \"Login\", kind: \"screen\", detail: \"route: /login\", storyId: \"pages-login--default\" },\n    { label: \"Submit credentials\", kind: \"action\", detail: \"trigger: form submit\" },\n    { label: \"Student dashboard\", kind: \"screen\", detail: \"route: /dashboard\", storyId: \"pages-dashboard--default\" },\n    { label: \"Open course catalog\", kind: \"action\", detail: \"nav: sidebar → Browse\" },\n    { label: \"Course detail\", kind: \"screen\", detail: \"route: /courses/:id\", storyId: \"pages-course--default\" },\n    { label: \"Enroll modal\", kind: \"modal\", detail: \"component: EnrollDialog\", storyId: \"components-enrolldialog--open\" },\n    { label: \"Enrolled — confirmation\", kind: \"end\", detail: \"effect: enrollment created\", storyId: \"pages-course--enrolled\" },\n  ],\n}\n\nexport default function Preview(): ReactElement {\n  return (\n    <div style={{ maxWidth: 560, margin: \"0 auto\", padding: 16 }}>\n      <JourneyGraph journey={FIXTURE} />\n    </div>\n  )\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 1412,
          "y": 3800
        },
        "size": {
          "width": 660,
          "height": 720
        },
        "rotation": 0,
        "zIndex": 24
      }
    ],
    "groups": [],
    "nextZIndex": 25,
    "selectedIds": []
  },
  "view": {
    "transform": {
      "scale": 0.193,
      "offset": {
        "x": 105,
        "y": 33
      }
    }
  }
}
