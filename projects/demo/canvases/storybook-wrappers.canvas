    "items": [
      {
        "id": "canvas-item-sbtier-core",
        "type": "markdown",
        "title": "① CORE — state & decision authoring",
        "source": "## ① CORE — state & decision authoring\n\nStateGrid  ·  StateMatrix  ·  RoleCanvas  ·  TrackedDecision  ·  DecisionsDashboard  ·  ABCanvas",
        "background": "#ffffff",
        "position": {
          "x": 160,
          "y": 140
        },
        "size": {
          "width": 1400,
          "height": 96
        },
        "rotation": 0,
        "zIndex": 1
      },
      {
        "id": "canvas-item-sbwrapper-stategrid",
        "type": "html",
        "title": "StateGrid",
        "sourceMode": "react",
        "sourceReact": "/**\n * StateGrid preview harness — self-contained for the gallery-poc canvas.\n * Inlines the StateGrid wrapper plus a sample Button so multiple states render.\n */\nimport React, { type ComponentType } from 'react';\n\ninterface StateEntry<P> {\n  label: string;\n  props: P;\n  pseudo?: Record<string, boolean>;\n}\n\ninterface StateGridProps<P> {\n  component: ComponentType<P>;\n  states: StateEntry<P>[];\n  cols?: number;\n}\n\nfunction StateGrid<P>({ component: Component, states, cols = 4 }: StateGridProps<P>) {\n  const rowMode = cols === 1;\n  return (\n    <div\n      className=\"state-grid\"\n      style={{\n        display: 'grid',\n        gridTemplateColumns: `repeat(${cols}, 1fr)`,\n        gap: rowMode ? '0.5rem' : '1rem',\n      }}\n    >\n      {states.map(({ label, props, pseudo }) => {\n        const pseudoCls = pseudo\n          ? Object.keys(pseudo).filter((k) => pseudo[k]).map((k) => `pseudo-${k}-all`).join(' ') || undefined\n          : undefined;\n        const rendered = pseudoCls ? <span className={pseudoCls}><Component {...props} /></span> : <Component {...props} />;\n        const labelStyle = {\n          fontSize: '0.7rem',\n          color: '#666',\n          textTransform: 'uppercase' as const,\n          letterSpacing: '0.06em',\n          fontWeight: 600,\n        };\n        return (\n          <div\n            key={label}\n            className=\"state-cell\"\n            style={{\n              background: '#f9fafb',\n              border: '1px solid #e2e0db',\n              borderRadius: 6,\n              padding: '1rem',\n              ...(rowMode\n                ? { display: 'grid', gridTemplateColumns: '140px 1fr', alignItems: 'center', gap: '1rem', textAlign: 'left' as const }\n                : { textAlign: 'center' as const }),\n            }}\n          >\n            <div className=\"state-label\" style={rowMode ? labelStyle : { ...labelStyle, marginBottom: '0.6rem' }}>\n              {label}\n            </div>\n            {rendered}\n          </div>\n        );\n      })}\n    </div>\n  );\n}\n\n// --- Fixtures ----------------------------------------------------------------\n\ninterface ButtonProps {\n  children: React.ReactNode;\n  disabled?: boolean;\n  loading?: boolean;\n}\n\nfunction Button({ children, disabled, loading }: ButtonProps) {\n  return (\n    <button\n      disabled={disabled || loading}\n      style={{\n        background: disabled ? '#cbd2dd' : '#2b5cd9',\n        color: 'white',\n        border: 'none',\n        borderRadius: 6,\n        padding: '0.5rem 1.1rem',\n        fontSize: '0.85rem',\n        cursor: disabled || loading ? 'not-allowed' : 'pointer',\n        opacity: disabled ? 0.7 : 1,\n      }}\n    >\n      {loading ? 'Loading…' : children}\n    </button>\n  );\n}\n\nexport default function Preview() {\n  return (\n    <div style={{ padding: 24, background: '#ffffff', fontFamily: 'system-ui, sans-serif' }}>\n      <StateGrid\n        component={Button}\n        cols={4}\n        states={[\n          { label: 'Default', props: { children: 'Click me' } },\n          { label: 'Hover', props: { children: 'Click me' }, pseudo: { hover: true } },\n          { label: 'Disabled', props: { children: 'Click me', disabled: true } },\n          { label: 'Loading', props: { children: 'Click me', loading: true } },\n        ]}\n      />\n    </div>\n  );\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 160,
          "y": 276
        },
        "size": {
          "width": 740,
          "height": 320
        },
        "rotation": 0,
        "zIndex": 2
      },
      {
        "id": "canvas-item-sbwrapper-statematrix",
        "type": "html",
        "title": "StateMatrix",
        "sourceMode": "react",
        "sourceReact": "/**\n * StateMatrix preview harness — self-contained for the gallery-poc canvas.\n * Inlines the StateMatrix wrapper plus a sample Button so the\n * variants × states catalog table renders.\n */\nimport React, { type ComponentType } from 'react';\n\ninterface MatrixAxis<P> {\n  label: string;\n  props?: Partial<P>;\n  pseudo?: Record<string, boolean>;\n}\n\ninterface StateMatrixProps<P> {\n  component: ComponentType<P>;\n  variants: MatrixAxis<P>[];\n  states: MatrixAxis<P>[];\n  baseProps?: Partial<P>;\n}\n\nfunction pseudoClassName(pseudo?: Record<string, boolean>): string | undefined {\n  if (!pseudo) return undefined;\n  const cls = Object.keys(pseudo)\n    .filter((k) => pseudo[k])\n    .map((k) => `pseudo-${k}-all`)\n    .join(' ');\n  return cls || undefined;\n}\n\nconst headCell: React.CSSProperties = {\n  fontSize: '0.68rem',\n  color: '#666',\n  textTransform: 'uppercase',\n  letterSpacing: '0.06em',\n  fontWeight: 600,\n  padding: '0.5rem 0.9rem',\n  textAlign: 'center',\n  whiteSpace: 'nowrap',\n};\n\nfunction StateMatrix<P>({ component: Component, variants, states, baseProps }: StateMatrixProps<P>) {\n  return (\n    <table className=\"state-matrix\" style={{ borderCollapse: 'separate', borderSpacing: '0.75rem' }}>\n      <thead>\n        <tr>\n          <th style={{ ...headCell, textAlign: 'left' }} />\n          {states.map((s) => (\n            <th key={s.label} style={headCell}>{s.label}</th>\n          ))}\n        </tr>\n      </thead>\n      <tbody>\n        {variants.map((v) => (\n          <tr key={v.label}>\n            <th scope=\"row\" style={{ ...headCell, textAlign: 'left' }}>{v.label}</th>\n            {states.map((s) => {\n              const props = { ...(baseProps ?? {}), ...(v.props ?? {}), ...(s.props ?? {}) } as P;\n              const pseudoCls = pseudoClassName({ ...(v.pseudo ?? {}), ...(s.pseudo ?? {}) });\n              return (\n                <td\n                  key={s.label}\n                  className=\"matrix-cell\"\n                  style={{\n                    background: '#f9fafb',\n                    border: '1px solid #e2e0db',\n                    borderRadius: 6,\n                    padding: '1rem',\n                    textAlign: 'center',\n                    verticalAlign: 'middle',\n                  }}\n                >\n                  {pseudoCls ? (\n                    <span className={pseudoCls}><Component {...props} /></span>\n                  ) : (\n                    <Component {...props} />\n                  )}\n                </td>\n              );\n            })}\n          </tr>\n        ))}\n      </tbody>\n    </table>\n  );\n}\n\n// --- Fixtures ----------------------------------------------------------------\n\ninterface ButtonProps {\n  children: React.ReactNode;\n  variant?: 'primary' | 'secondary' | 'ghost';\n  disabled?: boolean;\n  loading?: boolean;\n}\n\nconst VARIANT_STYLE: Record<string, React.CSSProperties> = {\n  primary: { background: '#2b5cd9', color: 'white', border: '1px solid #2b5cd9' },\n  secondary: { background: '#eef1f6', color: '#1a1a1a', border: '1px solid #cbd2dd' },\n  ghost: { background: 'transparent', color: '#2b5cd9', border: '1px solid transparent' },\n};\n\nfunction Button({ children, variant = 'primary', disabled, loading }: ButtonProps) {\n  return (\n    <button\n      disabled={disabled || loading}\n      style={{\n        ...VARIANT_STYLE[variant],\n        borderRadius: 6,\n        padding: '0.45rem 1rem',\n        fontSize: '0.82rem',\n        cursor: disabled || loading ? 'not-allowed' : 'pointer',\n        opacity: disabled ? 0.5 : 1,\n        whiteSpace: 'nowrap',\n      }}\n    >\n      {loading ? 'Loading…' : children}\n    </button>\n  );\n}\n\nexport default function Preview() {\n  return (\n    <div style={{ padding: 24, background: '#ffffff', fontFamily: 'system-ui, sans-serif' }}>\n      <StateMatrix\n        component={Button}\n        baseProps={{ children: 'Button' }}\n        variants={[\n          { label: 'Primary', props: { variant: 'primary' } },\n          { label: 'Secondary', props: { variant: 'secondary' } },\n          { label: 'Ghost', props: { variant: 'ghost' } },\n        ]}\n        states={[\n          { label: 'Default' },\n          { label: 'Hover', pseudo: { hover: true } },\n          { label: 'Disabled', props: { disabled: true } },\n          { label: 'Loading', props: { loading: true } },\n        ]}\n      />\n    </div>\n  );\n}\n",
        "sandbox": "allow-scripts allow-same-origin allow-forms allow-modals allow-popups",
        "position": {
          "x": 972,
          "y": 276
        },
        "size": {
          "width": 780,
          "height": 380
        },
        "rotation": 0,
        "zIndex": 3
